/// Generic system-wide audit log added in round 7 for BRD §5.4 ("full audit logs")
/// + §3.1 ("audit logging of all actions" for admin role). Covers admin actions on
/// users, configuration changes, auth events, advisor + client workflow actions,
/// and a curated set of sensitive data-access reads. SubscriptionAuditLog and
/// AdvisorBrandingAuditLog are intentionally NOT migrated here — see the schema
/// decision in the round-7 design doc and the comment block in audit-log.ts.
///
/// `actorUserId` is NOT a foreign key. Audit history must outlive the user it
/// references so a regulator-style "who did X" query still resolves after a
/// hard delete. `actorRole` and `actorEmailHash` are cached at write time so
/// the row is self-contained.
model AuditLog {
  id             String    @id @default(cuid())
  /// Null only for system actions (e.g. cron jobs, retention sweep itself).
  actorUserId    String?
  /// Cached at write time so audit-log queries don't need to join User.
  actorRole      UserRole?
  /// 8-char sha256 prefix of lowercase email. Same shape as auth.config.ts emailHash().
  actorEmailHash String?
  /// "<entity>.<verb>" e.g. "user.create", "bank_question.update". String not enum so
  /// adding new actions doesn't require a migration. Application-layer enum is in
  /// src/lib/audit/audit-log.ts (AUDIT_ACTIONS).
  action         String
  /// Entity targeted by the action. e.g. "User", "AssessmentBankQuestion",
  /// "PlatformSettings", "InviteCode".
  entityType     String
  /// Null for bulk actions; otherwise the row's id (or composite key serialized).
  entityId       String?
  /// State diff. Both nullable: create has null beforeData; delete has null afterData;
  /// pure read events have both null. Always pass through redactForAudit() before
  /// writing — see src/lib/audit/redact.ts.
  beforeData     Json?
  afterData      Json?
  /// Free-form context: stripe event id, target user's email hash, etc. Same redaction
  /// rules as the data fields.
  metadata       Json?
  /// Truncated for privacy: IPv4 last octet zeroed, IPv6 last 64 bits zeroed.
  /// See src/lib/audit/ip.ts.
  ipAddress      String?
  /// Truncated to 256 chars at write time.
  userAgent      String?
  createdAt      DateTime  @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// --- Enhanced assessment engine (recommendations, rules, pillar config) ---

/// C1 (BRD §4.4): tiered recommendations classification.
/// BASELINE = automated baseline recs the engine surfaces from rules.
/// ENHANCED = manual overlay added by admin (Akili Risk staff curation).
enum RecommendationTier {
  BASELINE
  ENHANCED
}

/// C1 (BRD §4.4): catalog filter dimension. Nullable on existing rows.
enum RecommendationComplexity {
  LOW
  MEDIUM
  HIGH
}

/// C1 (BRD §4.4): catalog filter dimension. Nullable on existing rows.
/// HYBRID = some self-serve setup followed by advisory completion.
enum ImplementationType {
  DIY
  ADVISORY
  HYBRID
}

model ServiceRecommendation {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String
  priority      Int      @default(1)
  estimatedCost String?
  timeframe     String?
  provider      String?
  metadata      Json?
  isActive      Boolean  @default(true)
  /// C1 (BRD §4.4): see RecommendationTier. Defaults BASELINE for back-compat.
  tier               RecommendationTier        @default(BASELINE)
  /// C1 (BRD §4.4): nullable so existing rows render as "—" in admin filters.
  complexity         RecommendationComplexity?
  /// C1 (BRD §4.4): nullable so existing rows render as "—" in admin filters.
  implementationType ImplementationType?

  /// Risk Solutions Library (Phase 22): enriched catalog fields
  slug               String?               @unique
  shortDescription   String?               @db.VarChar(280)
  icon               String?               @db.VarChar(60)
  expectedOutcome    String?               @db.Text
  tags               String[]              @default([])
  /// Ordered list of implementation steps (platform playbook).
  /// Shape: { steps: [{ title, description, estimatedDuration?, sortOrder }] }
  playbook           Json?
  externalUrl        String?
  /// Comma-separated service IDs that should be completed first.
  prerequisites      String[]              @default([])
  /// Phase 22 (D-09/D-11): per-field override policy declarations.
  /// Shape: [{ field: string, tier: "PROTECTED" | "CONFIGURABLE" | "ADDITION" }]
  overridePolicies   Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recommendationRules               RecommendationRule[]
  assessmentRecommendations         AssessmentRecommendation[]
  enterpriseSolutionCustomizations   EnterpriseSolutionCustomization[]
  advisorSolutionCustomizations      AdvisorSolutionCustomization[]

  @@index([category, priority])
  @@index([isActive])
  @@index([tier])
}

model ScoringRule {
  id             String   @id @default(cuid())
  questionId     String
  ruleName       String
  description    String?
  priority       Int      @default(1)
  conditions     Json
  scoreModifiers Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([questionId])
  @@index([isActive, priority])
}

model RecommendationRule {
  id                      String   @id @default(cuid())
  serviceRecommendationId String
  ruleName                String
  description             String?
  triggerConditions       Json
  pillarThresholds        Json?
  questionConditions      Json?
  priority                Int      @default(1)
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  serviceRecommendation ServiceRecommendation @relation(fields: [serviceRecommendationId], references: [id], onDelete: Cascade)
  advisorClones         AdvisorRecommendationRule[] @relation("AdvisorRecRulePlatformSource")
  enterpriseClones      EnterpriseRecommendationRule[] @relation("EnterpriseRecRulePlatformSource")

  @@index([serviceRecommendationId])
  @@index([isActive, priority])
}

enum RecommendationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  DECLINED
  COMPLETED
  /// Phase 22: implementation-focused lifecycle states
  GENERATED
  INCLUDED
  DEFERRED
  IN_PROGRESS
}

/// Phase 22 (D-21): client-managed task progress
enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  READY_FOR_REVIEW
  COMPLETED
}

/// Phase 22 (D-21): advisor-managed validation
enum ValidationStatus {
  PENDING_REVIEW
  VERIFIED
  NEEDS_FOLLOWUP
}

/// Phase 22 (D-06): advisor priority override
enum AdvisorPriority {
  HIGH
  MEDIUM
  LOW
}

model AssessmentRecommendation {
  id                      String                 @id @default(cuid())
  assessmentId            String
  serviceRecommendationId String
  triggerReason           Json
  customization           Json?
  priority                Int
  status                  RecommendationStatus   @default(PENDING)
  advisorNotes            String?

  /// Risk Solutions Library: lifecycle timestamp tracking
  statusUpdatedAt         DateTime?
  acceptedAt              DateTime?
  startedAt               DateTime?
  completedAt             DateTime?
  declinedAt              DateTime?
  declinedReason          String?               @db.Text
  implementationNotes     String?               @db.Text
  /// Engine-computed urgency (0-100) based on risk level and trigger severity.
  urgencyScore            Float?
  /// Expected risk-score improvement if this solution is implemented.
  projectedImpact         Float?
  /// Records which layers (platform/enterprise/advisor) contributed at match time.
  /// Shape: { platform: bool, enterprise: { id, name } | null, advisor: { id, name } | null }
  sourceLayerSummary      Json?                 @map("source_layer_summary")

  /// Phase 22 (D-21): client-managed task progress
  taskStatus              TaskStatus             @default(NOT_STARTED)
  /// Phase 22 (D-21): advisor-managed validation
  validationStatus        ValidationStatus       @default(PENDING_REVIEW)
  /// Phase 22 (D-22): whether this action requires advisor validation
  requiresValidation      Boolean                @default(false)
  /// Phase 22 (D-06): advisor override of urgencyScore priority
  advisorPriority         AdvisorPriority?
  /// Phase 22 (D-05): hide recommendation from client view
  hiddenFromClient        Boolean                @default(false)
  /// Phase 22 (D-08): reason for deferring
  deferredReason          String?                @db.Text
  /// Phase 22 (D-08): optional revisit date for deferred items
  deferredRevisitDate     DateTime?
  /// Phase 22 (D-08): trigger event for deferred items (e.g., "After business valuation")
  deferredTriggerEvent    String?                @db.Text
  /// Phase 22 (D-20): platform-defined responsible roles
  responsibleRoles        String[]               @default([])
  /// Phase 22 (D-20): freeform assignee list. Shape: [{ name, role, org }]
  assignees               Json?
  /// Phase 22: time horizon for SAP grouping: "immediate", "strategic", "ongoing"
  timeHorizon             String?                @db.VarChar(20)

  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  assessment            Assessment            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  serviceRecommendation ServiceRecommendation @relation(fields: [serviceRecommendationId], references: [id])
  milestones            SolutionMilestone[]
  activities            SolutionActivity[]

  @@unique([assessmentId, serviceRecommendationId])
  @@index([assessmentId])
  @@index([status])
  @@index([taskStatus, hiddenFromClient])
}

/// §4.5 commit 3 (BRD §4.5): Reporting Engine — choice of cover layout
/// and brand vocabulary for a published report.
enum ReportTemplate {
  /// Default Akili / Belvedere lockup; no advisor branding on the cover.
  BELVEDERE
  /// Co-branded: advisor firmName + logo on the cover; advisor brand
  /// colors when subscription tier permits.
  COBRANDED
}

/// §4.5 commit 3 (BRD §4.5): state machine for Report rows.
enum ReportStatus {
  /// Editable by the assigned advisor. At most one DRAFT per assessment
  /// (enforced by a Postgres partial unique index — see migration
  /// 20260522120000_reporting_engine).
  DRAFT
  /// Frozen rendering. Never mutated after publish (status flips to
  /// SUPERSEDED on next publish; see PUBLISHED → SUPERSEDED transition
  /// inside the publishReport transaction).
  PUBLISHED
  /// Prior PUBLISHED row that has been replaced by a newer publish for
  /// the same assessment. Preserves history; remains downloadable.
  SUPERSEDED
}

/// §4.5 commit 3 (BRD §4.5): immutable advisor-published rendering of an
/// Assessment at a point in time. See `docs/operations/s3-sse-kms.md`-
/// adjacent docs once a report-engine ops doc lands; for now the
/// canonical reference is `src/lib/actions/report-actions.ts`
/// (publishReport / republishReport) and `src/lib/pdf/build-report-
/// snapshot.ts` (snapshot shape).
model Report {
  id                String         @id @default(cuid())
  assessmentId      String
  /// Monotonic per assessment. v1 is the first PUBLISHED (or backfilled)
  /// row; DRAFT rows hold the next-version-to-be value pre-emptively so
  /// the publish action is a single update with no re-numbering. The
  /// (assessmentId, version) UNIQUE index catches the rare race where
  /// two advisors hit Publish at once.
  version           Int
  status            ReportStatus   @default(DRAFT)
  templateChoice    ReportTemplate @default(COBRANDED)

  /// Editorial overlay. Edited freely on DRAFT rows; frozen on publish.
  executiveSummary  String?
  /// Map of `{ [serviceRecommendationId]: notesString }`. Frozen on
  /// publish so future edits to the live `AssessmentRecommendation`
  /// rows don't retroactively rewrite a published Report's notes.
  advisorNotes      Json?
  /// Staff-queued recommended actions from question-bank review (draft
  /// overlay; frozen into snapshot on publish).
  queuedPillarActions Json?

  /// Frozen scoring/breakdown/recommendations data, shaped exactly the
  /// way `AssessmentReport`'s `data` prop expects it (interface in
  /// `src/lib/pdf/components/AssessmentReport.tsx`). Populated at
  /// publish time from `buildReportSnapshot(assessmentId)`. Null on
  /// DRAFT rows — DRAFT preview renders from live data with a
  /// "DRAFT — NOT PUBLISHED" watermark.
  snapshotData      Json?
  /// Frozen advisor-branding data (firmName, logoUrl, brandName,
  /// tagline, colors, supportEmail, supportPhone). Same selection as
  /// `getAdvisorBrandingForPDF` returns. Null on DRAFT rows.
  brandingSnapshot  Json?

  publishedAt       DateTime?
  /// User id of whoever clicked Publish. ADVISOR for normal flows,
  /// ADMIN for the republish action. Null on DRAFT rows + on rows whose
  /// publisher account was later deleted (FK is ON DELETE SET NULL).
  publishedById     String?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  assessment        Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  publishedBy       User?          @relation("ReportPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  @@unique([assessmentId, version])
  @@index([assessmentId, status])
  @@index([publishedAt])
}

/// BRD §6.3 Phase 3 / Epic 5.10: the engagement record created when a
/// client accepts the recommendation on their RISK PROFILE. Tracks status
/// from ACCEPTED through MEETING_SCHEDULED, IN_PROGRESS, COMPLETE (or
/// DECLINED if the advisor later reverses). One engagement per assessment.
model PortfolioEngagement {
  id                 String                    @id @default(cuid())
  assessmentId       String                    @unique
  clientId           String
  advisorId          String

  status             PortfolioEngagementStatus @default(ACCEPTED)
  acceptedAt         DateTime                  @default(now())
  meetingScheduledAt DateTime?
  meetingAt          DateTime?
  completedAt        DateTime?
  declinedAt         DateTime?
  /// Advisor's working notes about the engagement. No PII rules beyond
  /// the usual application-layer encryption applied to free-text fields.
  notes              String?                   @db.Text

  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  client     User       @relation("PortfolioEngagementClient", fields: [clientId], references: [id], onDelete: Cascade)
  advisor    User       @relation("PortfolioEngagementAdvisor", fields: [advisorId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([advisorId])
  @@index([status])
}

model PillarConfiguration {
