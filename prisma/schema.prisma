// ---------------------------------------------------------------------------
// Risk Solutions Library: compose-at-read customization overlays
// ---------------------------------------------------------------------------

/// Enterprise-level overlay on a platform ServiceRecommendation.
/// Additive only: can override cost/timeframe/provider and append playbook
/// steps and notes, but cannot remove or hide platform content.
model EnterpriseSolutionCustomization {
  id                      String            @id @default(cuid())
  enterpriseId            String            @map("enterprise_id")
  serviceRecommendationId String            @map("service_recommendation_id")
  /// Override fields (null = inherit platform value)
  costOverride            String?           @map("cost_override")
  timeframeOverride       String?           @map("timeframe_override")
  providerOverride        String?           @map("provider_override")
  /// Additional playbook steps appended after platform steps.
  /// Shape: { steps: [{ title, description, estimatedDuration?, sortOrder }] }
  additionalPlaybook      Json?             @map("additional_playbook")
  /// Free-form notes visible to all advisors in the enterprise.
  notes                   String?           @db.Text
  isActive                Boolean           @default(true) @map("is_active")
  /// Phase 22 (D-14): whether this recommendation is required for the enterprise
  isRequired              Boolean           @default(false) @map("is_required")
  /// Phase 22 (D-14): enterprise priority adjustment (-N to +N relative to platform priority)
  priorityAdjustment      Int?              @map("priority_adjustment")
  /// Phase 22 (D-14): enterprise-specific compliance disclosures
  complianceDisclosures   String?           @db.Text @map("compliance_disclosures")
  /// Phase 22 (D-14): enterprise-specific implementation guidance
  customGuidance          String?           @db.Text @map("custom_guidance")
  /// Phase 22 (D-14): enterprise internal links. Shape: [{ url, label }]
  internalLinks           Json?             @map("internal_links")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  enterprise            AdvisorEnterprise     @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  serviceRecommendation ServiceRecommendation @relation(fields: [serviceRecommendationId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, serviceRecommendationId])
  @@index([enterpriseId])
  @@map("enterprise_solution_customizations")
}

/// Per-advisor overlay on a platform ServiceRecommendation.
/// Same additive-only semantics as the enterprise layer.
model AdvisorSolutionCustomization {
  id                      String            @id @default(cuid())
  advisorProfileId        String            @map("advisor_profile_id")
  serviceRecommendationId String            @map("service_recommendation_id")
  /// Override fields (null = inherit from enterprise or platform)
  costOverride            String?           @map("cost_override")
  timeframeOverride       String?           @map("timeframe_override")
  providerOverride        String?           @map("provider_override")
  /// Additional playbook steps appended after enterprise steps.
  additionalPlaybook      Json?             @map("additional_playbook")
  notes                   String?           @db.Text
  isActive                Boolean           @default(true) @map("is_active")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  advisorProfile        AdvisorProfile        @relation(fields: [advisorProfileId], references: [id], onDelete: Cascade)
  serviceRecommendation ServiceRecommendation @relation(fields: [serviceRecommendationId], references: [id], onDelete: Cascade)

  @@unique([advisorProfileId, serviceRecommendationId])
  @@index([advisorProfileId])
  @@map("advisor_solution_customizations")
}

enum MilestoneSource {
  PLATFORM
  ENTERPRISE
  ADVISOR
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
  BLOCKED
  DEFERRED
}

/// Materialized playbook step for an accepted recommendation.
/// Created when status transitions to ACCEPTED; each row is tagged
/// with the source layer that contributed it.
model SolutionMilestone {
  id                         String          @id @default(cuid())
  assessmentRecommendationId String          @map("assessment_recommendation_id")
  title                      String          @db.VarChar(200)
  description                String?         @db.Text
  estimatedDuration          String?         @map("estimated_duration") @db.VarChar(60)
  sortOrder                  Int             @default(0) @map("sort_order")
  source                     MilestoneSource @default(PLATFORM)
  status                     MilestoneStatus @default(NOT_STARTED)
  completedAt                DateTime?       @map("completed_at")
  dueDate                    DateTime?       @map("due_date")
  blockedReason              String?         @map("blocked_reason") @db.VarChar(500)
  deferredReason             String?         @map("deferred_reason") @db.VarChar(500)
  deferredRevisitDate        DateTime?       @map("deferred_revisit_date")
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")

  assessmentRecommendation AssessmentRecommendation @relation(fields: [assessmentRecommendationId], references: [id], onDelete: Cascade)

  @@index([assessmentRecommendationId])
  @@index([assessmentRecommendationId, sortOrder])
  @@map("solution_milestones")
}

/// Activity log entry for recommendation lifecycle events (status changes,
/// notes, milestone completions) and Phase 24 intelligence events (assessment
/// completions, score changes, cadence triggers). Append-only — never updated
/// or deleted.
model SolutionActivity {
  id                         String   @id @default(cuid())
  /// Nullable (Phase 24 D-11): intelligence events may not be tied to a
  /// specific recommendation. Existing recommendation-scoped events still
  /// populate this field; assessment-scoped events leave it null and use
  /// assessmentId instead.
  assessmentRecommendationId String?  @map("assessment_recommendation_id")
  /// Phase 24 (D-11): optional FK for assessment-scoped intelligence events
  /// (e.g., assessment_completed, score_calculated, cadence triggers).
  assessmentId               String?  @map("assessment_id")
  actorId                    String?  @map("actor_id")
  action                     String   @db.VarChar(60)
  detail                     Json?
  createdAt                  DateTime @default(now()) @map("created_at")

  assessmentRecommendation AssessmentRecommendation? @relation(fields: [assessmentRecommendationId], references: [id], onDelete: Cascade)
  assessment               Assessment?               @relation("AssessmentIntelligenceEvents", fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentRecommendationId])
  @@index([assessmentRecommendationId, createdAt])
  @@index([assessmentId])
  @@map("solution_activities")
}

/// Immutable advisor methodology frozen at intake start.
model IntakeSnapshot {
  id                 String   @id @default(cuid())
  intakeInterviewId  String   @unique @map("intake_interview_id")
  advisorProfileId   String   @map("advisor_profile_id")
  snapshotBlob       Json     @map("snapshot_blob")
  snapshotHash       String   @map("snapshot_hash") @db.VarChar(64)
  schemaVersion      Int      @default(2) @map("schema_version")
  takenAt            DateTime @default(now()) @map("taken_at")

  intakeInterview IntakeInterview @relation(fields: [intakeInterviewId], references: [id], onDelete: Cascade)
  advisorProfile  AdvisorProfile  @relation(fields: [advisorProfileId], references: [id], onDelete: Restrict)
  assessments     Assessment[]

  @@index([advisorProfileId])
  @@index([takenAt])
  @@map("intake_snapshots")
}

// ---------------------------------------------------------------------------
// Phase 24: Continuous Risk Improvement
// ---------------------------------------------------------------------------

/// Phase 24 (D-08): reassessment frequency options.
enum CadenceFrequency {
  QUARTERLY    // 90 days
  SEMI_ANNUAL  // 180 days
  ANNUAL       // 365 days
}

/// Phase 24 (D-08, D-09, D-10): per-client reassessment scheduling state.
/// The Review Cadence Engine manages the reassessment lifecycle — not just
/// reminders, but active scheduling and system-recommended reassessments.
model ReviewCadence {
  id                          String           @id @default(cuid())
  clientId                    String
  advisorProfileId            String
  frequency                   CadenceFrequency @default(ANNUAL)
  nextDueDate                 DateTime         @map("next_due_date")
  lastAssessmentId            String?          @map("last_assessment_id")
  /// Pitfall 5: track last reminder to prevent duplicate sends.
  lastReminderSentAt          DateTime?        @map("last_reminder_sent_at")
  /// true = advisor explicitly set; false = inherited from enterprise default.
  isOverridden                Boolean          @default(false) @map("is_overridden")
  /// true = AKILI system-initiated recommendation (D-09).
  systemRecommended           Boolean          @default(false) @map("system_recommended")
  systemRecommendationReason  String?          @map("system_recommendation_reason")
  createdAt                   DateTime         @default(now()) @map("created_at")
  updatedAt                   DateTime         @updatedAt @map("updated_at")

  client          User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  advisorProfile  AdvisorProfile  @relation(fields: [advisorProfileId], references: [id], onDelete: Cascade)
  lastAssessment  Assessment?     @relation(fields: [lastAssessmentId], references: [id], onDelete: SetNull)

  @@unique([clientId, advisorProfileId])
  @@index([nextDueDate])
  @@map("review_cadences")
}

// ---------------------------------------------------------------------------
// Phase 25: Executive Reporting
// ---------------------------------------------------------------------------

/// Phase 25 (D-01, D-03): Multi-assessment executive report with Draft ->
/// Published -> Superseded lifecycle. Scoped to (client, advisor) pair, not
/// a single assessment, because executive reports span the full risk story
/// across multiple assessments (D-22). The frozen executiveSnapshotData is
/// populated at publish time from buildExecutiveReportSnapshot(). Null on
/// DRAFT rows -- DRAFT preview renders from live data with a watermark.
///
/// Cascade rules (mirror Report model):
///   * client ON DELETE CASCADE -- RTBF on a client wipes every executive
///     report for them. Snapshot data includes client PII.
///   * advisorProfile ON DELETE CASCADE -- removing an advisor profile
///     removes their executive reports (orphaned without the advisor context).
///   * publishedBy ON DELETE SET NULL -- deleted advisor preserves report
///     attribution-as-null rather than orphaning published rows.
///
/// Partial unique index (one DRAFT per (clientId, advisorProfileId)):
///   Enforced by raw SQL in the migration -- Prisma DSL does not support
///   partial unique indexes. The index is:
///   CREATE UNIQUE INDEX "ExecutiveReport_clientId_advisorProfileId_draft_unique"
///       ON "ExecutiveReport"("clientId", "advisorProfileId") WHERE "status" = 'DRAFT';
model ExecutiveReport {
  id                     String       @id @default(cuid())
  /// Scoped to client, not assessment -- executive reports span multiple assessments (D-22).
  clientId               String
  advisorProfileId       String
  /// Monotonic per (clientId, advisorProfileId). DRAFT rows hold the next
  /// version value pre-emptively; publish transitions DRAFT -> PUBLISHED.
  version                Int
  /// Reuses existing ReportStatus enum (DRAFT/PUBLISHED/SUPERSEDED) per D-03.
  status                 ReportStatus @default(DRAFT)

  /// Reporting window. Advisor can override per D-23; default is "since last published."
  reportingPeriodStart   DateTime
  reportingPeriodEnd     DateTime

  /// Frozen multi-assessment snapshot at publish time. Null on DRAFT rows.
  executiveSnapshotData  Json?
  /// Frozen advisor branding at publish time. Null on DRAFT rows.
  brandingSnapshot       Json?

  /// Advisor-authored editorial fields. Editable freely on DRAFT rows;
  /// frozen into executiveSnapshotData at publish time (D-18).
  advisorNotes           String?
  meetingAgenda          String?
  /// String[] stored as Json (Prisma does not have a native String[] Json column).
  discussionPrompts      Json?

  publishedAt            DateTime?
  /// User id of whoever clicked Publish. Null on DRAFT rows and when publisher deleted.
  publishedById          String?

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  client          User          @relation("ExecutiveReportClient", fields: [clientId], references: [id], onDelete: Cascade)
  advisorProfile  AdvisorProfile @relation(fields: [advisorProfileId], references: [id], onDelete: Cascade)
  publishedBy     User?         @relation("ExecutiveReportPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  /// Natural per-(client, advisor, version) uniqueness. Catches concurrent publish races.
  @@unique([clientId, advisorProfileId, version])
  /// Covers "fetch DRAFT for this client+advisor" and "fetch PUBLISHED history" at index speed.
  @@index([clientId, advisorProfileId, status])
}
