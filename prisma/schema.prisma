// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADVISOR
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  /// Round-11 commit 2.4b (BRD §5.1.AUTH / phase B — soft-drop step 2):
  /// authoritative auth-path lookup column — the only stored form of
  /// the user's email. Deterministic AES-256-GCM ciphertext; UNIQUE +
  /// NOT NULL. Use the helpers in `src/lib/auth/user-email.ts`
  /// (findUserByEmail / userEmailWriteData / userEmailForDisplay /
  /// decryptUserEmail) rather than reading or writing this column
  /// directly. The plaintext `email` column was dropped in this
  /// commit's migration.
  emailCiphertext String    @unique
  emailVerified DateTime?
  /// Round-11 commit 3 (BRD §5.1.AUTH): nullable so client (role=USER)
  /// accounts can exist without a password. Advisor + admin accounts
  /// still set a real bcrypt hash. The credentials provider in
  /// auth.config.ts has a TIMING_FALLBACK_HASH defensive guard for null.
  password      String?
  name          String?
  firstName     String?
  lastName      String?
  image         String?
  role          UserRole  @default(USER)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  mfaRecoveryCodes Json?
  /// When false, ADVISOR users cannot use /advisor or advisor APIs (admin kill switch).
  advisorPortalAccessEnabled Boolean @default(true)
  /// Admin soft-delete: when set, user cannot sign in and should be excluded from active advisor lists.
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  assessments   Assessment[]
  householdMembers HouseholdMember[]
  intakeInterviews IntakeInterview[]
  advisorProfile AdvisorProfile?
  clientProfile  ClientProfile?
  clientAssignments ClientAdvisorAssignment[] @relation("ClientAssignments")
  documentRequirements DocumentRequirement[] @relation("ClientDocuments")
  notificationPreference NotificationPreference?
  subscription            Subscription?
  /// §4.5 commit 3 (BRD §4.5): Reports this user has published. Set-null on
  /// delete (deleted advisor preserves report attribution-as-null rather
  /// than orphaning published rows).
  publishedReports        Report[] @relation("ReportPublisher")

  /// Round-11 commit 2.4a: @@index([email]) + the phase-A
  /// User_emailCiphertext_idx are dropped at the SQL level by
  /// migration 20260508120000_user_email_ciphertext_phase_b_a; the
  /// `@unique` on emailCiphertext above is the new authoritative
  /// index.
  @@index([deletedAt])
}

enum SubscriptionTier {
  STARTER
  GROWTH
  PROFESSIONAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  GRACE_PERIOD
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripePriceId        String?
  stripeSubscriptionId String?            @unique
  tier                 SubscriptionTier
  status               SubscriptionStatus
  clientLimit          Int
  billingCycle         BillingCycle
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)

  // Branding Feature Flags
  basicBrandingEnabled    Boolean @default(false)
  advancedBrandingEnabled Boolean @default(false)
  customSubdomainEnabled  Boolean @default(false)
  whiteLabel              Boolean @default(false)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  /** Stripe `event.created` of the most recent webhook applied to this row.
   *  Used to drop out-of-order webhook deliveries (Stripe doesn't guarantee
   *  ordering). Distinct from `updatedAt` because admin actions also bump
   *  `updatedAt`, which would falsely "win" against legitimate webhook events. */
  lastStripeEventAt    DateTime?

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs SubscriptionAuditLog[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

/** Per-Stripe-event idempotency + observability log.
 *
 *  The webhook handler upserts a row keyed by Stripe's `event.id` BEFORE
 *  running any business logic. The dedupe gate is `processedAt != null` —
 *  PROCESSED and IGNORED both set processedAt (both are terminal, no need
 *  to re-run); FAILED leaves it null so Stripe's retry can take another
 *  attempt against the same row. RECEIVED rows are in-flight.
 *
 *  Recording IGNORED rows for unhandled event types gives us a complete
 *  audit trail of what Stripe sent us, even if our handler currently has no
 *  case for it. Volume can grow; consider a TTL/GC follow-up.
 */
model StripeWebhookEvent {
  /** Stripe's event.id, e.g. `evt_1Abc...`. Primary key for natural dedupe. */
  id            String                @id
  eventType     String
  /** Stripe's `event.created` (Unix seconds → Date). Snapshot at receipt
   *  time. Used by the ordering check inside subscription-mutating cases. */
  eventCreated  DateTime
  receivedAt    DateTime              @default(now())
  /** Set on terminal outcomes (PROCESSED, IGNORED). Null while RECEIVED or
   *  if the handler threw (FAILED). The dedupe gate is `processedAt != null`. */
  processedAt   DateTime?
  status        WebhookProcessStatus  @default(RECEIVED)

  @@index([eventType, receivedAt])
}

enum WebhookProcessStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

model SubscriptionAuditLog {
  id               String            @id @default(cuid())
  subscriptionId   String
  action           String
  previousTier     SubscriptionTier?
  newTier          SubscriptionTier?
  metadata         Json?
  timestamp        DateTime          @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

/** Singleton row (`id = "default"`): global toggles managed in Admin → Settings. */
model PlatformSettings {
  id     String @id @default("default")
  /** Advisor nav + /advisor/governance dashboard (Family Portfolio, metrics). */
  advisorGovernanceDashboardEnabled Boolean @default(true)
  /** Advisor nav + /advisor/intelligence (portfolio risk views). */
  advisorRiskIntelligenceEnabled    Boolean @default(true)
  /// A2 (BRD §4.2 + §7.1): risk-tier cutoffs in 0–100 resilience-percent space.
  /// Configured at /admin/scoring/thresholds. NEW scoring runs use these;
  /// previously-persisted PillarScore.riskLevel rows are NOT retroactively
  /// recomputed (would require a re-score). Defaults match the original
  /// hardcoded values from governance-rubric.ts so behavior is unchanged
  /// until an admin edits them.
  riskThresholdLow    Int @default(80)
  riskThresholdMedium Int @default(60)
  riskThresholdHigh   Int @default(40)
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  mfaVerified  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)

  @@unique([identifier, token])
}

/// Round-11 commit 2 (BRD §5.1.AUTH): magic-link authentication tokens for
/// client users. Sibling to NextAuth's VerificationToken (which holds
/// password-reset tokens for advisor accounts). Single-use, 15-minute
/// expiry by default; raw token hashed via SHA-256 before storage.
model MagicLinkToken {
  id           String    @id @default(cuid())
  /// SHA-256 hash of the random 32-byte token sent to the user. The raw
  /// token only exists in transit (the email body) and during validation.
  tokenHash    String    @unique
  /// Email the link is bound to. Validation uses tokenHash for lookup;
  /// email is stored for audit + display only.
  email        String
  /// Optional FK to the originating InviteCode when the link is issued
  /// as part of advisor invitation. Null for self-service sign-in
  /// requests by existing users. SetNull on delete so an invite removal
  /// doesn't cascade-kill in-flight tokens.
  inviteCodeId String?
  expires      DateTime
  used         Boolean   @default(false)
  /// When the link was clicked (used flips true). Null until clicked.
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  inviteCode   InviteCode? @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expires])
}

model Assessment {
  id            String           @id @default(cuid())
  userId        String
  /// C2 (BRD §7.2): bumped each time rescoreAssessment runs. Pre-rescore
  /// the value is 1 (default); first rescore writes 2, etc. Lets the UI
  /// surface "v3" badges without consulting the audit log.
  version       Int              @default(1)
  status        AssessmentStatus @default(IN_PROGRESS)
  currentPillar String?
  currentQuestionIndex Int?      @default(0)
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  /// C2 (BRD §7.2): set by rescoreAssessment / rescoreAssessmentsBulk so
  /// the per-client view + PDF cover can render "Last re-scored Mar 4, 2026".
  /// NULL = never re-scored (true of every pre-C2 row).
  lastRescoredAt DateTime?
  updatedAt     DateTime         @updatedAt
  approvalId    String?          // Links to IntakeApproval for customized assessments

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     AssessmentResponse[]
  scores        PillarScore[]
  recommendations AssessmentRecommendation[]
  ruleExecutions    RuleExecution[]
  /// §4.5 commit 3 (BRD §4.5): published + draft + superseded report
  /// versions. Cascade on delete so RTBF wipes every Report row for this
  /// assessment (frozen reports include client PII in snapshotData).
  reports        Report[]

  @@index([userId])
  @@index([status])
}

model AssessmentResponse {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String
  pillar       String
  subCategory  String
  /// Round-11 commit 2.5b (BRD §5.1): random-IV AES-256-GCM ciphertext
  /// of JSON.stringify(answer). Nullable for `skipped = true` rows.
  /// Use the helpers in `src/lib/data/response-content.ts`
  /// (encryptAnswer / decryptAnswer<T>) — never read this column
  /// directly. The plaintext `answer Json` column was dropped by the
  /// 2.5b finalize migration; this column was renamed from
  /// `answerCiphertext` to take its place.
  answer       String?
  skipped      Boolean  @default(false)
  answeredAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
}

model PillarScore {
  id           String    @id @default(cuid())
  assessmentId String
  pillar       String
  score        Float
  riskLevel    RiskLevel
  breakdown    Json
  missingControls Json?
  calculatedAt DateTime  @default(now())

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, pillar])
  @@index([assessmentId])
}

/// Family-governance structured assessment: question copy and visibility per risk area (six intake/scoring pillars).
model AssessmentBankQuestion {
  id                  String   @id @default(cuid())
  questionId          String   @unique
  riskAreaId          String
  sortOrderGlobal     Int
  isVisible           Boolean  @default(true)
  text                String   @db.Text
  helpText            String?  @db.Text
  learnMore           String?  @db.Text
  riskRelevance       String?  @db.Text
  type                String
  options             Json?
  required            Boolean
  weight              Int
  scoreMap            Json
  branchingDependsOn  String?
  branchingPredicate  Json?
  profileConditionKey String?
  /// Yes/no only: when true, "yes" is excluded from maturity aggregation (follow-ups define 0–3).
  omitMaturityScoreWhenYes Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([riskAreaId])
  @@index([riskAreaId, sortOrderGlobal])
  @@index([isVisible, sortOrderGlobal])
}

/// Belvedere `categories` row: scored workbook pillars vs. audio/script intake (see `kind`).
enum PillarCategoryKind {
  INTAKE
  ASSESSMENT

  @@map("pillar_category_kind")
}

/// Belvedere workbook taxonomy (DDL source of truth). Maps to SQL table `categories`.
model PillarCategory {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String             @unique @db.VarChar(50)
  name         String             @db.VarChar(200)
  sheetName    String?            @map("sheet_name") @db.VarChar(200)
  displayOrder Int                @default(0) @map("display_order")
  /// `INTAKE` = audio interview script; `ASSESSMENT` = scored pillar workbook tabs.
  kind         PillarCategoryKind @default(ASSESSMENT) @map("category_kind")
  sections     PillarSection[]

  @@index([displayOrder])
  @@map("categories")
}

/// Section within a pillar category (e.g. rubric block A–F or numbered block).
/// Maps to SQL table `sections`.
model PillarSection {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId String         @map("category_id") @db.Uuid
  code         String         @db.VarChar(20)
  name         String         @db.VarChar(300)
  objective    String?        @db.Text
  weightPct    Int?           @map("weight_pct")
  displayOrder Int            @default(0) @map("display_order")

  category  PillarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  questions PillarQuestion[]

  @@unique([categoryId, code])
  @@index([categoryId])
  @@index([displayOrder])
  @@map("sections")
}

/// Question row aligned to Belvedere DDL (answer labels, types, cross-references).
/// Maps to SQL table `questions`.
model PillarQuestion {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId            String   @map("section_id") @db.Uuid
  questionNumber       String?  @map("question_number") @db.VarChar(20)
  questionText         String   @map("question_text") @db.Text
  answerType           String   @default("scored_0_3") @map("answer_type") @db.VarChar(50)
  answer0              String?  @map("answer_0") @db.Text
  answer1              String?  @map("answer_1") @db.Text
  answer2              String?  @map("answer_2") @db.Text
  answer3              String?  @map("answer_3") @db.Text
  whyThisMatters       String?  @map("why_this_matters") @db.Text
  recommendedActions   String?  @map("recommended_actions") @db.Text
  isSubQuestion         Boolean  @default(false) @map("is_sub_question")
  crossReference       String?  @map("cross_reference") @db.Text
  displayOrder         Int      @default(0) @map("display_order")
  isVisible            Boolean  @default(true) @map("is_visible")

  section PillarSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, questionNumber])
  @@unique([sectionId, displayOrder])
  @@index([sectionId])
  @@index([answerType])
  @@index([isVisible])
  @@map("questions")
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InvitationStatus {
  SENT
  OPENED
  REGISTERED
  EXPIRED
}

enum ClientWorkflowStage {
  INVITED
  REGISTERED
  INTAKE_IN_PROGRESS
  INTAKE_COMPLETE
  ASSESSMENT_IN_PROGRESS
  ASSESSMENT_COMPLETE
  DOCUMENTS_REQUIRED
  COMPLETE
}

enum FamilyRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  GRANDCHILD
  GRANDPARENT
  OTHER
}

enum GovernanceRole {
  DECISION_MAKER
  ADVISOR
  SUCCESSOR
  BENEFICIARY
  TRUSTEE
  EXECUTOR
  OTHER
}

enum IntakeStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// Round-11 commit 2.2 (BRD §5.1 amendment): household-member sex.
/// Optional — the scoring engine doesn't currently consume sex, so
/// requiring it would be UX cost without product value.
enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

/// Round-11 commit 2.2 (BRD §5.1 amendment): demographic-only household
/// member. The fullName / age / occupation / phone / email / notes
/// columns + the share-flag were dropped per the "minimization by
/// omission" strategy. The advisor sees household composition by
/// structure (sex × birthYear × relationship × governanceRoles)
/// without identifying any individual.
model HouseholdMember {
  id             String             @id @default(cuid())
  userId         String
  /// Auto-generated server-side at create time. Format: "Member A",
  /// "Member B", … (first unused letter A–Z per household), then
  /// "Member 27", "Member 28", … for the rare household > 26 members.
  /// Used wherever the old fullName was displayed.
  displayLabel   String
  /// Birth year, replaces the old `age` Int column. Nullable for
  /// "unknown / prefer not to say"; scoring derives the bucketed age
  /// (under-18, under-26) from `currentYear - birthYear` at read time.
  birthYear      Int?
  /// Demographic field (BRD §5.1 amendment). Optional.
  sex            Sex?
  /// Option D session 1: optional household-member full name, re-added
  /// after round-11's drop. Encrypted at rest with random-IV AES-256-GCM
  /// via `src/lib/data/client-pii.ts`. Coexists with displayLabel —
  /// clients who consent to fullName see "Jane Doe" everywhere; clients
  /// who don't see "Member A" / "Member B" (existing displayLabel
  /// default). Visibility gated per ClientAdvisorAssignment.fieldVisibility.
  fullName       String?
  /// Option D session 1: optional household-member phone, re-added.
  /// Same encryption + visibility shape as fullName.
  phone          String?
  /// Option D session 1: optional free-form notes per household member
  /// (e.g. role context, health considerations). Same encryption +
  /// visibility shape as fullName.
  notes          String?
  relationship   FamilyRelationship
  governanceRoles GovernanceRole[]
  isResident     Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, displayLabel])
  @@index([userId])
}

model IntakeInterview {
  id                   String      @id @default(cuid())
  userId               String
  status               IntakeStatus @default(NOT_STARTED)
  currentQuestionIndex Int         @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  submittedAt          DateTime?
  updatedAt            DateTime    @updatedAt

  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses            IntakeResponse[]
  approval             IntakeApproval?

  @@index([userId])
  @@index([status])
}

model IntakeResponse {
  id                  String              @id @default(cuid())
  interviewId         String
  questionId          String
  audioUrl            String?
  audioS3Key          String?
  audioContentType    String?
  audioDuration       Float?
  /// Round-11 commit 2.5b (BRD §5.1): random-IV AES-256-GCM ciphertext
  /// of the transcription text. Stored as iv:tag:ct hex. Use the
  /// helpers in `src/lib/data/response-content.ts`
  /// (encryptTranscription / decryptTranscription) — never read
  /// this column directly.
  transcription       String?
  /// Round-11 commit 2.5a: denormalized "non-empty plaintext exists"
  /// flag — set at write time. Pipeline filters use this instead of
  /// the encrypted `transcription` column (where IS-NOT-NULL +
  /// non-empty checks would be meaningless on ciphertext).
  hasTranscription    Boolean             @default(false)
  transcriptionStatus TranscriptionStatus @default(PENDING)
  answeredAt          DateTime?
  updatedAt           DateTime            @updatedAt

  interview           IntakeInterview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, questionId])
  @@index([interviewId])
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_INTAKE
  INTAKE_UPDATED
  NEW_LEAD
  SYSTEM
  CLIENT_REGISTERED
  MILESTONE_COMPLETE
  WORKFLOW_STALLED
  DOCUMENT_UPLOADED
}

enum FamilyComplexity {
  SINGLE_HOUSEHOLD
  MULTI_GENERATIONAL
  FAMILY_BUSINESS_INVOLVED
}

model GovernanceReviewLead {
  id                    String            @id @default(cuid())
  name                  String
  email                 String
  familyOfficeName      String
  primaryAdvisor        String?
  familyComplexity      FamilyComplexity
  promptedInterest      String?
  assignedAdvisorId     String?
  assignedAt            DateTime?
  createdAt             DateTime          @default(now())
  assignedAdvisor       AdvisorProfile?   @relation("GovernanceLeadAssignment", fields: [assignedAdvisorId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
  @@index([assignedAdvisorId])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  prefillEmail String?  // optional: prefill signup form when this code is used
  expiresAt  DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  createdBy   String?
  status      InvitationStatus @default(SENT)
  statusUpdatedAt DateTime @default(now())
  personalMessage String?
  /** When true, advisor requested that the client may skip intake (waived). */
  intakeWaived  Boolean  @default(false)
  clientName  String?
  resendCount Int       @default(0)

  advisor     AdvisorProfile? @relation(fields: [createdBy], references: [id])
  /// Round-11 commit 2: magic-link tokens issued for this invite (one
  /// invite may have multiple in-flight tokens if re-issued).
  magicLinkTokens MagicLinkToken[]

  @@index([code])
  @@index([createdBy])
  @@index([status])
}

model AdvisorProfile {
  id               String                     @id @default(cuid())
  userId           String                     @unique
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  specializations  String[]
  licenseNumber    String?
  firmName         String?
  bio              String?
  phone            String?
  jobTitle         String?
  logoUrl          String?

  // Enhanced Branding Fields
  brandName        String?
  tagline          String?
  primaryColor     String?
  secondaryColor   String?
  accentColor      String?
  websiteUrl       String?
  emailFooterText  String?
  supportEmail     String?
  supportPhone     String?

  // S3 Asset Management
  logoS3Key        String?
  logoContentType  String?
  logoFileSize     Int?
  logoUploadedAt   DateTime?

  // Feature Control
  brandingEnabled     Boolean @default(true)
  customDomainEnabled Boolean @default(false)

  /// Option D session 1 (BRD §5.1 amendment): per-tenant policy
  /// controlling which optional PII fields the advisor's clients are
  /// asked to fill in during intake. Default: all 5 fields enabled
  /// (opt-out shape per round-12 Option D sign-off).
  ///
  /// Shape:
  ///   {
  ///     "schemaVersion": 1,
  ///     "fields": {
  ///       "User.name": boolean,
  ///       "ClientProfile.phone": boolean,
  ///       "HouseholdMember.fullName": boolean,
  ///       "HouseholdMember.phone": boolean,
  ///       "HouseholdMember.notes": boolean
  ///     }
  ///   }
  ///
  /// Updated via /advisor/settings/pii-policy; emits PII_POLICY_UPDATE
  /// (and per-field PII_POLICY_FIELD_ENABLE / _DISABLE rows on toggle).
  /// New ClientAdvisorAssignment rows snapshot this into
  /// `fieldVisibility` at create time so a later policy change doesn't
  /// retroactively hide data already collected from an existing client.
  piiPolicy        Json     @default("{\"schemaVersion\":1,\"fields\":{\"User.name\":true,\"ClientProfile.phone\":true,\"HouseholdMember.fullName\":true,\"HouseholdMember.phone\":true,\"HouseholdMember.notes\":true}}")

  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  clientAssignments ClientAdvisorAssignment[] @relation("AdvisorAssignments")
  intakeWaiversSet  ClientAdvisorAssignment[] @relation("IntakeWaiverSetBy")
  approvals        IntakeApproval[]
  notifications    AdvisorNotification[]
  invitations      InviteCode[]
  documentRequirements DocumentRequirement[]
  assignedGovernanceLeads GovernanceReviewLead[] @relation("GovernanceLeadAssignment")
  subdomain        AdvisorSubdomain?
  auditLogs        AdvisorBrandingAuditLog[]

  @@index([userId])
  @@index([brandingEnabled])
}

/// Round-11 session 2 / commit 2.1 (BRD §5.1 amendment): the contact +
/// address + DOB fields were dropped per the "minimization by omission"
/// strategy. Only User.email is stored as client identity. The model is
/// retained as a near-stub so future per-client metadata has an FK
/// target without re-introducing a 1:1 table; removable entirely in a
/// follow-up if no new fields land.
model ClientProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Option D session 1 (BRD §5.1 amendment): optional client phone,
  /// re-added after round-11's drop. Encrypted at rest with random-IV
  /// AES-256-GCM via `src/lib/data/client-pii.ts`. Populated only when
  /// the advisor's piiPolicy.fields["ClientProfile.phone"] is true AND
  /// the client provided one during intake. Read-side visibility is
  /// gated per ClientAdvisorAssignment.fieldVisibility.
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model ClientAdvisorAssignment {
  id         String           @id @default(cuid())
  clientId   String
  advisorId  String
  assignedAt DateTime         @default(now())
  status     AssignmentStatus @default(ACTIVE)
  /// When set, client may skip submitted/approved intake for nav and /assessment access.
  intakeWaivedAt             DateTime?
  intakeWaivedByAdvisorId    String?
  /// Option D session 1: per-assignment snapshot of which PII fields
  /// THIS advisor can see for THIS client. Two advisors assigned to
  /// the same client can therefore have different visibility (e.g. a
  /// reassigned client may consent to a different field set on
  /// reassignment). Same JSON shape as AdvisorProfile.piiPolicy.
  ///
  /// Snapshotted from the advisor's piiPolicy at assignment-create
  /// time + via SQL backfill in this commit's migration for rows that
  /// pre-date this commit. Application-layer read sites treat null
  /// defensively as "fall through to advisor.piiPolicy" for in-flight
  /// assignments created during the migration window.
  fieldVisibility            Json?
  intakeWaivedBy             AdvisorProfile? @relation("IntakeWaiverSetBy", fields: [intakeWaivedByAdvisorId], references: [id], onDelete: SetNull)
  client     User             @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  advisor    AdvisorProfile   @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)

  @@unique([clientId, advisorId])
  @@index([advisorId])
  @@index([clientId])
}

model IntakeApproval {
  id           String          @id @default(cuid())
  interviewId  String          @unique
  advisorId    String
  status       ApprovalStatus  @default(PENDING)
  focusAreas   String[]
  notes        String?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  interview    IntakeInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  advisor      AdvisorProfile  @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([interviewId])
}

model AdvisorNotification {
  id          String           @id @default(cuid())
  advisorId   String
  type        NotificationType
  title       String
  message     String
  referenceId String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  advisor     AdvisorProfile   @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, read])
}

model DocumentRequirement {
  id           String   @id @default(cuid())
  advisorId    String   // AdvisorProfile.id
  clientId     String   // User.id (client)
  name         String   // e.g., "Trust Agreement", "Tax Return"
  description  String?  // Additional details about what's needed
  required     Boolean  @default(true)
  fulfilled    Boolean  @default(false)
  fulfilledAt  DateTime?
  fileKey      String?  // S3 object key
  fileName     String?  // Original file name for display
  fileSize     Int?     // File size in bytes
  fileMimeType String?  // Validated MIME type
  lastReminderSentAt DateTime? // Track when last reminder was sent to prevent spam
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  advisor      AdvisorProfile @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  client       User           @relation("ClientDocuments", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([clientId])
  @@index([advisorId, clientId])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email notification toggles
  emailEnabled          Boolean @default(true)
  emailMilestones       Boolean @default(true)   // NOTIFY-03: milestone completions
  emailReminders        Boolean @default(true)    // NOTIFY-02: assessment reminders
  emailStalled          Boolean @default(true)    // NOTIFY-04: stalled workflow alerts
  emailRegistrations    Boolean @default(true)    // NOTIFY-01: client registrations

  // Frequency control
  reminderFrequencyDays Int     @default(7)       // Min days between reminder emails

  // Quiet hours (optional, store as "HH:MM" strings, UTC)
  quietStart   String?  // e.g., "22:00"
  quietEnd     String?  // e.g., "08:00"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
}

// Advisor Subdomain Management
model AdvisorSubdomain {
  id             String    @id @default(cuid())
  advisorId      String    @unique
  subdomain      String    @unique
  isActive       Boolean   @default(false)
  dnsVerified    Boolean   @default(false)
