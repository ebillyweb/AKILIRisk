model AdvisorProfile {
  id               String                     @id @default(cuid())
  userId           String                     @unique
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enterpriseId     String?
  enterprise       AdvisorEnterprise?         @relation(fields: [enterpriseId], references: [id], onDelete: SetNull)
  enterpriseMembership EnterpriseMembership?
  specializations  String[]
  licenseNumber    String?
  firmName         String?
  bio              String?
  phone            String?
  jobTitle         String?
  logoUrl          String?

  // Enhanced Branding Fields
  brandName        String?
  tagline          String?
  landingKicker    String?
  landingHeadline  String?
  landingSubheadline String?
  landingSubtext   String?
  landingFeatureCards Json?
  primaryColor     String?
  secondaryColor   String?
  accentColor      String?
  websiteUrl       String?
  emailFooterText  String?
  supportEmail     String?
  supportPhone     String?

  // S3 Asset Management
  logoS3Key        String?
  logoContentType  String?
  logoFileSize     Int?
  logoUploadedAt   DateTime?

  // Feature Control
  brandingEnabled     Boolean @default(true)
  customDomainEnabled Boolean @default(false)
  /// US-49 (BRD §3.5 FR-HH-04): tenant-wide; when false, clients under
  /// this advisor cannot use /profiles and assessment skips profile logic.
  householdProfilesEnabled Boolean @default(true)

  /// Option D session 1 (BRD §5.1 amendment): per-tenant policy
  /// controlling which optional PII fields the advisor's clients are
  /// asked to fill in during intake. Default: all 5 fields enabled
  /// (opt-out shape per round-12 Option D sign-off).
  ///
  /// Shape:
  ///   {
  ///     "schemaVersion": 1,
  ///     "fields": {
  ///       "User.name": boolean,
  ///       "ClientProfile.phone": boolean,
  ///       "HouseholdMember.fullName": boolean,
  ///       "HouseholdMember.phone": boolean,
  ///       "HouseholdMember.notes": boolean
  ///     }
  ///   }
  ///
  /// Updated via /advisor/settings/pii-policy; emits PII_POLICY_UPDATE
  /// (and per-field PII_POLICY_FIELD_ENABLE / _DISABLE rows on toggle).
  /// New ClientAdvisorAssignment rows snapshot this into
  /// `fieldVisibility` at create time so a later policy change doesn't
  /// retroactively hide data already collected from an existing client.
  piiPolicy        Json     @default("{\"schemaVersion\":1,\"fields\":{\"User.name\":true,\"ClientProfile.phone\":true,\"HouseholdMember.fullName\":true,\"HouseholdMember.phone\":true,\"HouseholdMember.notes\":true}}")

  /// When starter content was cloned into advisor-owned methodology tables.
  starterContentClonedAt DateTime? @map("starter_content_cloned_at")
  /// Last platform Pillar.catalogVersion seen by this advisor.
  catalogVersionSeen     Int       @default(0) @map("catalog_version_seen")
  /// Active intake question bank for this practice (solo advisors; synced from firm for members).
  intakeQuestionBankMode IntakeQuestionBankMode @default(PLATFORM) @map("intake_question_bank_mode")
  /// Active assessment question bank for this practice (solo advisors; synced from firm for members).
  assessmentQuestionBankMode IntakeQuestionBankMode @default(PLATFORM) @map("assessment_question_bank_mode")
  /// When false, automated reminder emails are not sent to this practice's clients.
  clientReminderEmailsEnabled  Boolean @default(true)
  /// When false, automated workflow reminder emails are not sent to this practice's advisors.
  advisorReminderEmailsEnabled Boolean @default(true)

  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  clientAssignments ClientAdvisorAssignment[] @relation("AdvisorAssignments")
  intakeWaiversSet  ClientAdvisorAssignment[] @relation("IntakeWaiverSetBy")
  approvals        IntakeApproval[]
  notifications    AdvisorNotification[]
  signals            AdvisorSignal[]
  invitations      InviteCode[]
  documentRequirements DocumentRequirement[]
  facilitatedSessions FacilitatedSession[]
  assignedGovernanceLeads GovernanceReviewLead[] @relation("GovernanceLeadAssignment")
  subdomain        AdvisorSubdomain?
  auditLogs        AdvisorBrandingAuditLog[]
  pillarOverrides       AdvisorPillarOverride[]
  pillarQuestions       AdvisorPillarQuestion[]
  intakeQuestions       AdvisorIntakeQuestion[]
  pillarNarratives      AdvisorPillarNarrative[]
  recommendationRules        AdvisorRecommendationRule[]
  solutionCustomizations     AdvisorSolutionCustomization[]
  intakeSnapshots            IntakeSnapshot[]
  /// Phase 24: review cadence entries managed by this advisor.
  reviewCadences             ReviewCadence[]
  /// Phase 25: executive reports this advisor has generated.
  executiveReports           ExecutiveReport[]

  @@index([userId])
  @@index([enterpriseId])
  @@index([brandingEnabled])
}

/// Round-11 session 2 / commit 2.1 (BRD §5.1 amendment): the contact +
/// address + DOB fields were dropped per the "minimization by omission"
/// strategy. Only User.email is stored as client identity. The model is
/// retained as a near-stub so future per-client metadata has an FK
/// target without re-introducing a 1:1 table; removable entirely in a
/// follow-up if no new fields land.
model ClientProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Option D session 1 (BRD §5.1 amendment): optional client phone,
  /// re-added after round-11's drop. Encrypted at rest with random-IV
  /// AES-256-GCM via `src/lib/data/client-pii.ts`. Populated only when
  /// the advisor's piiPolicy.fields["ClientProfile.phone"] is true AND
  /// the client provided one during intake. Read-side visibility is
  /// gated per ClientAdvisorAssignment.fieldVisibility.
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model ClientAdvisorAssignment {
  id         String           @id @default(cuid())
  clientId   String
  advisorId  String
  assignedAt DateTime         @default(now())
  status     AssignmentStatus @default(ACTIVE)
  /// When set, client may skip submitted/approved intake for nav and /assessment access.
  intakeWaivedAt             DateTime?
  intakeWaivedByAdvisorId    String?
  /// Epic 5.11: assessment scope when intake is waived (1–6 pillar ids). Required to unlock assessment.
  includedPillars            String[]         @default([]) @map("included_pillars")
  /// Scoring emphasis within included pillars; empty means all included at waiver scope save.
  focusAreas                 String[]         @default([]) @map("focus_areas")
  /// Option D session 1: per-assignment snapshot of which PII fields
  /// THIS advisor can see for THIS client. Two advisors assigned to
  /// the same client can therefore have different visibility (e.g. a
  /// reassigned client may consent to a different field set on
  /// reassignment). Same JSON shape as AdvisorProfile.piiPolicy.
  ///
  /// Snapshotted from the advisor's piiPolicy at assignment-create
  /// time + via SQL backfill in this commit's migration for rows that
  /// pre-date this commit. Application-layer read sites treat null
  /// defensively as "fall through to advisor.piiPolicy" for in-flight
  /// assignments created during the migration window.
  fieldVisibility            Json?
  intakeWaivedBy             AdvisorProfile? @relation("IntakeWaiverSetBy", fields: [intakeWaivedByAdvisorId], references: [id], onDelete: SetNull)
  client     User             @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  advisor    AdvisorProfile   @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)

  @@unique([clientId, advisorId])
  @@index([advisorId])
  @@index([clientId])
}

model IntakeApproval {
  id           String          @id @default(cuid())
  interviewId  String          @unique
  advisorId    String
  status       ApprovalStatus  @default(PENDING)
  /// Epic 5.11: advisor-selected assessment scope (1–6 canonical pillar ids).
  includedPillars String[]     @default([]) @map("included_pillars")
  /// Scoring emphasis within included pillars; defaults to all included at approve.
  focusAreas   String[]
  /// Snapshot of intake-based pillar recommendations at approval time (audit).
  pillarRecommendations Json?   @map("pillar_recommendations")
  notes        String?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  interview    IntakeInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  advisor      AdvisorProfile  @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([interviewId])
}

/// Epic 5.11 US-73–75: advisor-led intake + assessment through preview.
model FacilitatedSession {
  id               String                   @id @default(cuid())
  clientId         String                   @map("client_id")
  advisorProfileId String                   @map("advisor_profile_id")
  status           FacilitatedSessionStatus @default(INTAKE)
  interviewId      String?                  @map("interview_id")
  assessmentId     String?                  @map("assessment_id")
  startedAt        DateTime                 @default(now()) @map("started_at")
  completedAt      DateTime?                @map("completed_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  client           User                     @relation("FacilitatedSessionClient", fields: [clientId], references: [id], onDelete: Cascade)
  advisor          AdvisorProfile           @relation(fields: [advisorProfileId], references: [id], onDelete: Cascade)

  @@index([clientId, advisorProfileId, status])
  @@index([advisorProfileId, status])
  @@map("facilitated_sessions")
}

model AdvisorNotification {
  id          String           @id @default(cuid())
  advisorId   String
  type        NotificationType
  title       String
  message     String
  referenceId String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  advisor     AdvisorProfile   @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, read])
}

model AdvisorSignal {
  id          String       @id @default(cuid())
  advisorId   String
  clientId    String
  source      SignalSource @default(INTERNAL_ASSESSMENT)
  type        SignalType
  /// critical | moderate | low
  severity    String
  title       String
  message     String
  payload     Json?
  dedupeKey   String
  readAt      DateTime?
  createdAt   DateTime     @default(now())

  advisor     AdvisorProfile @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  client      User           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([advisorId, dedupeKey])
  @@index([advisorId, createdAt(sort: Desc)])
  @@index([advisorId, readAt])
  @@index([clientId])
}

model DocumentRequirement {
  id           String   @id @default(cuid())
  advisorId    String   // AdvisorProfile.id
  clientId     String   // User.id (client)
  name         String   // e.g., "Trust Agreement", "Tax Return"
  description  String?  // Additional details about what's needed
  required     Boolean  @default(true)
  fulfilled    Boolean  @default(false)
  fulfilledAt  DateTime?
  fileKey      String?  // S3 object key
