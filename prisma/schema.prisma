/// Round-11 commit 2.2 (BRD §5.1 amendment): household-member sex.
/// Optional — the scoring engine doesn't currently consume sex, so
/// requiring it would be UX cost without product value.
enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

/// Round-11 commit 2.2 (BRD §5.1 amendment): demographic-only household
/// member. The fullName / age / occupation / phone / email / notes
/// columns + the share-flag were dropped per the "minimization by
/// omission" strategy. The advisor sees household composition by
/// structure (sex × birthYear × relationship × governanceRoles)
/// without identifying any individual.
model HouseholdMember {
  id             String             @id @default(cuid())
  userId         String
  /// Auto-generated server-side at create time. Format: "Member A",
  /// "Member B", … (first unused letter A–Z per household), then
  /// "Member 27", "Member 28", … for the rare household > 26 members.
  /// Used wherever the old fullName was displayed.
  displayLabel   String
  /// Birth year, replaces the old `age` Int column. Nullable for
  /// "unknown / prefer not to say"; scoring derives the bucketed age
  /// (under-18, under-26) from `currentYear - birthYear` at read time.
  birthYear      Int?
  /// Demographic field (BRD §5.1 amendment). Optional.
  sex            Sex?
  /// Option D session 1: optional household-member full name, re-added
  /// after round-11's drop. Encrypted at rest with random-IV AES-256-GCM
  /// via `src/lib/data/client-pii.ts`. Coexists with displayLabel —
  /// clients who consent to fullName see "Jane Doe" everywhere; clients
  /// who don't see "Member A" / "Member B" (existing displayLabel
  /// default). Visibility gated per ClientAdvisorAssignment.fieldVisibility.
  fullName       String?
  /// Option D session 1: optional household-member phone, re-added.
  /// Same encryption + visibility shape as fullName.
  phone          String?
  /// Option D session 1: optional free-form notes per household member
  /// (e.g. role context, health considerations). Same encryption +
  /// visibility shape as fullName.
  notes          String?
  relationship   FamilyRelationship
  governanceRoles GovernanceRole[]
  isResident     Boolean            @default(true)
  /// US-48 (BRD §3.5 FR-HH-03): when false, member is omitted from advisor
  /// surfaces but still drives client assessment personalization.
  shareWithAdvisor Boolean          @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, displayLabel])
  @@index([userId])
}

model IntakeInterview {
  id                   String      @id @default(cuid())
  userId               String
  status               IntakeStatus @default(NOT_STARTED)
  currentQuestionIndex Int         @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  submittedAt          DateTime?
  /// When set, this interview is hidden from active pipeline/client intake flows.
  archivedAt           DateTime?   @map("archived_at")
  updatedAt            DateTime    @updatedAt

  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses            IntakeResponse[]
  approval             IntakeApproval?
  snapshot             IntakeSnapshot?

  @@index([userId])
  @@index([status])
  @@index([archivedAt])
}

model IntakeResponse {
  id                  String              @id @default(cuid())
  interviewId         String
  questionId          String
  textResponse        String?
  audioUrl            String?
  audioS3Key          String?
  audioContentType    String?
  audioDuration       Float?
  /// Round-11 commit 2.5b (BRD §5.1): random-IV AES-256-GCM ciphertext
  /// of the transcription text. Stored as iv:tag:ct hex. Use the
  /// helpers in `src/lib/data/response-content.ts`
  /// (encryptTranscription / decryptTranscription) — never read
  /// this column directly.
  transcription       String?
  /// Round-11 commit 2.5a: denormalized "non-empty plaintext exists"
  /// flag — set at write time. Pipeline filters use this instead of
  /// the encrypted `transcription` column (where IS-NOT-NULL +
  /// non-empty checks would be meaningless on ciphertext).
  hasTranscription    Boolean             @default(false)
  transcriptionStatus TranscriptionStatus @default(PENDING)
  /// Advisor-led sessions may skip intake questions without an answer.
  skipped             Boolean             @default(false)
  answeredAt          DateTime?
  updatedAt           DateTime            @updatedAt

  interview           IntakeInterview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  adminNote           IntakeResponseAdminNote?
  /// US-46c: zero-or-more advisor notes — one per assigned advisor. Two
  /// active advisors on the same client can each leave their own note.
  advisorNotes        IntakeResponseAdvisorNote[]

  @@unique([interviewId, questionId])
  @@index([interviewId])
}

/// US-46b: platform-admin advisory note on a single intake answer.
/// Does not modify transcription/audio or pipeline scoring.
model IntakeResponseAdminNote {
  id               String   @id @default(cuid())
  intakeResponseId String   @unique
  body             String   @db.Text
  createdByUserId  String
  updatedByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  intakeResponse IntakeResponse @relation(fields: [intakeResponseId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("IntakeResponseAdminNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy      User?          @relation("IntakeResponseAdminNoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
}

/// US-46c: per-advisor advisory note on a single intake answer. Sister to
/// IntakeResponseAdminNote (US-46b) — both channels coexist on the same
/// response and neither overwrites the other. `advisorId` is the advisor
/// User (not AdvisorProfile) for parity with createdBy/updatedBy. Tenant
/// isolation (ACTIVE ClientAdvisorAssignment) is enforced at the
/// application layer, not the DB schema.
model IntakeResponseAdvisorNote {
  id               String   @id @default(cuid())
  intakeResponseId String
  advisorId        String
  body             String   @db.Text
  createdByUserId  String
  updatedByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  intakeResponse IntakeResponse @relation(fields: [intakeResponseId], references: [id], onDelete: Cascade)
  advisor        User           @relation("IntakeResponseAdvisorNoteAdvisor", fields: [advisorId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("IntakeResponseAdvisorNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy      User?          @relation("IntakeResponseAdvisorNoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([intakeResponseId, advisorId])
  @@index([advisorId])
  @@index([createdByUserId])
}

