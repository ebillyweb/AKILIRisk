  createdAt   DateTime  @default(now())
  createdBy   String?
  status      InvitationStatus @default(SENT)
  statusUpdatedAt DateTime @default(now())
  personalMessage String?
  /** When true, advisor requested that the client may skip intake (waived). */
  intakeWaived  Boolean  @default(false)
  /// Epic 5.11: assessment scope when intake is waived at invite time (1–6 pillar ids).
  includedPillars String[] @default([]) @map("included_pillars")
  /// Scoring emphasis within included pillars; empty means all included at provision.
  focusAreas      String[] @default([]) @map("focus_areas")
  clientName  String?
