// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADVISOR
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  /// Round-11 commit 2.4b (BRD §5.1.AUTH / phase B — soft-drop step 2):
  /// authoritative auth-path lookup column — the only stored form of
  /// the user's email. Deterministic AES-256-GCM ciphertext; UNIQUE +
  /// NOT NULL. Use the helpers in `src/lib/auth/user-email.ts`
  /// (findUserByEmail / userEmailWriteData / userEmailForDisplay /
  /// decryptUserEmail) rather than reading or writing this column
  /// directly. The plaintext `email` column was dropped in this
  /// commit's migration.
  emailCiphertext String    @unique
  /// Pseudonymous workspace label for client (USER) accounts, e.g. CL-8F3K-29QX.
  clientReferenceCode String? @unique
  emailVerified DateTime?
  /// Round-11 commit 3 (BRD §5.1.AUTH): nullable so client (role=USER)
  /// accounts can exist without a password. Advisor + admin accounts
  /// still set a real bcrypt hash. The credentials provider in
  /// auth.config.ts has a TIMING_FALLBACK_HASH defensive guard for null.
  password      String?
  /// Set when the user's password no longer meets platform policy; gates workspace until updated.
  passwordChangeRequired Boolean @default(false)
  /// PlatformSettings.passwordPolicyRevision satisfied when this password was last set.
  passwordPolicyRevision Int @default(0)
  name          String?
  firstName     String?
  lastName      String?
  image         String?
  role          UserRole  @default(USER)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  mfaRecoveryCodes Json?
  /// When false, ADVISOR users cannot use /advisor or advisor APIs (admin kill switch).
  advisorPortalAccessEnabled Boolean @default(true)
  /// Admin soft-delete: when set, user cannot sign in and should be excluded from active advisor lists.
  deletedAt     DateTime?
  /// Super-admin flag: test clients/advisors stay operational but are excluded from platform dashboards.
  isTestAccount Boolean   @default(false)
  /// Set when the user completes a successful sign-in (after MFA when enabled).
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  assessments   Assessment[]
  householdMembers HouseholdMember[]
  intakeInterviews IntakeInterview[]
  advisorProfile AdvisorProfile?
  clientProfile  ClientProfile?
  clientAssignments ClientAdvisorAssignment[] @relation("ClientAssignments")
  advisorSignals    AdvisorSignal[]
  documentRequirements DocumentRequirement[] @relation("ClientDocuments")
  notificationPreference NotificationPreference?
  subscription            Subscription?
  /// §4.5 commit 3 (BRD §4.5): Reports this user has published. Set-null on
  /// delete (deleted advisor preserves report attribution-as-null rather
  /// than orphaning published rows).
  publishedReports        Report[] @relation("ReportPublisher")
  intakeResponseAdminNotesCreated     IntakeResponseAdminNote[]     @relation("IntakeResponseAdminNoteCreatedBy")
  intakeResponseAdminNotesUpdated     IntakeResponseAdminNote[]     @relation("IntakeResponseAdminNoteUpdatedBy")
  assessmentResponseAdminNotesCreated AssessmentResponseAdminNote[] @relation("AssessmentResponseAdminNoteCreatedBy")
  assessmentResponseAdminNotesUpdated AssessmentResponseAdminNote[] @relation("AssessmentResponseAdminNoteUpdatedBy")
  /// US-46c: advisor-scoped advisory notes on individual intake/assessment
  /// answers. `advisorId` is the advisor User; createdBy/updatedBy are the
  /// audit-trail authors (always the same User row in practice but kept
  /// separate so the FK semantics mirror the admin tables).
  intakeResponseAdvisorNotesOwned       IntakeResponseAdvisorNote[]     @relation("IntakeResponseAdvisorNoteAdvisor")
  intakeResponseAdvisorNotesCreated     IntakeResponseAdvisorNote[]     @relation("IntakeResponseAdvisorNoteCreatedBy")
  intakeResponseAdvisorNotesUpdated     IntakeResponseAdvisorNote[]     @relation("IntakeResponseAdvisorNoteUpdatedBy")
  assessmentResponseAdvisorNotesOwned   AssessmentResponseAdvisorNote[] @relation("AssessmentResponseAdvisorNoteAdvisor")
  assessmentResponseAdvisorNotesCreated AssessmentResponseAdvisorNote[] @relation("AssessmentResponseAdvisorNoteCreatedBy")
  assessmentResponseAdvisorNotesUpdated AssessmentResponseAdvisorNote[] @relation("AssessmentResponseAdvisorNoteUpdatedBy")
  /// BRD §6.3 Phase 3 / Epic 5.10: portfolio engagements where this user
  /// is the client (cascade with the User row) or the advisor (restrict
  /// so engagements aren't orphaned by accidental advisor deletion).
  portfolioEngagementsAsClient  PortfolioEngagement[] @relation("PortfolioEngagementClient")
  portfolioEngagementsAsAdvisor PortfolioEngagement[] @relation("PortfolioEngagementAdvisor")
  /// Epic 5.11: advisor-led live sessions for this client.
  facilitatedSessions           FacilitatedSession[]  @relation("FacilitatedSessionClient")
  /// Enterprise advisor plan: at most one firm membership per user.
  enterpriseMembership          EnterpriseMembership?
  /// Firms where this user is the billing contact (typically the OWNER).
  billingContactEnterprises     AdvisorEnterprise[]   @relation("EnterpriseBillingContact")
  /// Phase 24: review cadence entries where this user is the client.
  reviewCadences                ReviewCadence[]
  /// Phase 25: executive reports where this user is the client.
  executiveReports              ExecutiveReport[] @relation("ExecutiveReportClient")
  /// Phase 25: executive reports this user has published (advisor/admin).
  publishedExecutiveReports     ExecutiveReport[] @relation("ExecutiveReportPublisher")

  /// Round-11 commit 2.4a: @@index([email]) + the phase-A
  /// User_emailCiphertext_idx are dropped at the SQL level by
  /// migration 20260508120000_user_email_ciphertext_phase_b_a; the
  /// `@unique` on emailCiphertext above is the new authoritative
  /// index.
  @@index([deletedAt])
}

enum SubscriptionTier {
  ESSENTIALS
  PROFESSIONAL
  BUSINESS
  PLATINUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  GRACE_PERIOD
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum EnterpriseRole {
  OWNER
  ADMIN
  ADVISOR
}

enum EnterpriseMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum EnterprisePaymentMethod {
  WIRE
  CARD
}

enum AdvisorEnterpriseStatus {
  ACTIVE
  PROVISIONING
  SUSPENDED
}

model AdvisorEnterprise {
  id                    String                  @id @default(cuid())
  name                  String
  slug                  String                  @unique
  status                AdvisorEnterpriseStatus @default(ACTIVE)
  seatLimit             Int
  clientLimit           Int
  perAdvisorClientLimit Int
  paymentMethod         EnterprisePaymentMethod @default(WIRE)
  billingContactUserId  String?
  billingContact        User?                   @relation("EnterpriseBillingContact", fields: [billingContactUserId], references: [id], onDelete: SetNull)
  /// Canonical firm branding (Phase 3). Client-facing surfaces resolve here when
  /// member profiles carry `enterpriseId`.
  brandName             String?
  tagline               String?
  landingKicker         String?
  landingHeadline       String?
  landingSubheadline    String?
  landingSubtext        String?
  landingFeatureCards   Json?
  primaryColor          String?
  secondaryColor        String?
  accentColor           String?
  websiteUrl            String?
  emailFooterText       String?
  supportEmail          String?
  supportPhone          String?
  logoUrl               String?
  logoS3Key             String?
  logoContentType       String?
  logoFileSize          Int?
  logoUploadedAt        DateTime?
  brandingEnabled                Boolean                 @default(true)
  implementationTrackingEnabled  Boolean                 @default(true)
  /// Enterprise OWNER/ADMIN: what ADVISOR-role team members see in the workspace.
  advisorMemberPortfolioVisible     Boolean              @default(true)
  advisorMemberAssessmentLeadsVisible Boolean            @default(true)
  advisorMemberMethodologyVisible   Boolean              @default(true)
  advisorMemberEngagementsVisible   Boolean              @default(true)
  advisorMemberReassessmentVisible  Boolean              @default(true)
  advisorMemberProductToursVisible  Boolean              @default(true)
  /// When true, hide tier-gated sidebar items from ADVISOR-role members (vs showing locked).
  advisorMemberHideTierLockedNav    Boolean              @default(false)
  /// When true, ADVISOR-role team members may skip intake on invites and in the pipeline.
  advisorMemberSkipIntakeEnabled    Boolean              @default(false)
  /// When true, ADVISOR-role team members may skip post-intake review in live sessions and use default pillars.
  advisorMemberSkipPostIntakeReviewEnabled Boolean       @default(false)
  /// When true, ADVISOR-role team members may request and track client document requirements.
  advisorMemberDocumentRequirementsEnabled Boolean       @default(true)
  /// When true, show Strategic Action Plan in the client portal and advisor guidance workflows.
  advisorMemberActionPlanEnabled             Boolean       @default(true)
  /// When true, ADVISOR-role team members see every client in the firm, not only their own assignments.
  advisorMemberSharedClientVisibilityEnabled Boolean       @default(false)
  /// When true, ADVISOR-role members may edit personal branding for assigned clients.
  advisorMemberPersonalBrandingEnabled Boolean           @default(false)
  /// When true (and personal branding enabled), members may claim their own subdomain.
  advisorMemberSubdomainEditable       Boolean           @default(false)
  /// Firm default: show Client reference codes instead of email in member workspaces.
  advisorMemberPseudonymousLabelingDefault Boolean       @default(false)
  /// Firm default: whether members collect client legal names on intake.
  advisorMemberCollectClientLegalNameDefault Boolean     @default(true)
  /// When true, ADVISOR-role members follow firm client data defaults (owners/admins exempt).
  advisorMemberClientDataPolicyLocked    Boolean         @default(false)
  /// Firm-wide intake question bank source: platform catalog or custom questions only.
  intakeQuestionBankMode                 IntakeQuestionBankMode @default(PLATFORM) @map("intake_question_bank_mode")
  /// Firm-wide assessment question bank source: platform catalog or custom questions only.
  assessmentQuestionBankMode             IntakeQuestionBankMode @default(PLATFORM) @map("assessment_question_bank_mode")
  /// When false, automated reminder emails are not sent to firm clients (assessment, documents).
  clientReminderEmailsEnabled            Boolean                @default(true)
  /// When false, automated workflow reminder emails are not sent to firm advisors.
  advisorReminderEmailsEnabled           Boolean                @default(true)
  /// Phase 24 (D-08): enterprise-wide default reassessment frequency.
  defaultCadenceFrequency        CadenceFrequency        @default(ANNUAL)
  customDomainEnabled            Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  subscription          Subscription?
  memberships           EnterpriseMembership[]
  advisorProfiles       AdvisorProfile[]
  subdomain                     AdvisorSubdomain?
  recommendationRules           EnterpriseRecommendationRule[]
  solutionCustomizations        EnterpriseSolutionCustomization[]
  pillarOverrides               EnterprisePillarOverride[]
  pillarQuestions               EnterprisePillarQuestion[]
  intakeQuestions               EnterpriseIntakeQuestion[]
  pillarNarratives              EnterprisePillarNarrative[]

  @@index([billingContactUserId])
  @@index([status])
}

model EnterpriseMembership {
  id               String                     @id @default(cuid())
  enterpriseId     String
  userId           String                     @unique
  advisorProfileId String?                    @unique
  role             EnterpriseRole
  status           EnterpriseMembershipStatus @default(INVITED)
  invitedEmail     String?
  invitedAt        DateTime?
  acceptedAt       DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  enterprise     AdvisorEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  advisorProfile AdvisorProfile?   @relation(fields: [advisorProfileId], references: [id], onDelete: SetNull)

  @@unique([enterpriseId, userId])
  @@index([enterpriseId])
  @@index([advisorProfileId])
  @@index([status])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String?            @unique
  enterpriseId         String?            @unique
  stripeCustomerId     String?            @unique
  stripePriceId        String?
  stripeSubscriptionId String?            @unique
  tier                 SubscriptionTier
  status               SubscriptionStatus
  clientLimit          Int
  billingCycle         BillingCycle
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)

  // Branding Feature Flags
  basicBrandingEnabled    Boolean @default(false)
  advancedBrandingEnabled Boolean @default(false)
  customSubdomainEnabled  Boolean @default(false)
  whiteLabel              Boolean @default(false)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  /** Stripe `event.created` of the most recent webhook applied to this row.
   *  Used to drop out-of-order webhook deliveries (Stripe doesn't guarantee
   *  ordering). Distinct from `updatedAt` because admin actions also bump
   *  `updatedAt`, which would falsely "win" against legitimate webhook events. */
  lastStripeEventAt    DateTime?

  user       User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  enterprise AdvisorEnterprise? @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  auditLogs  SubscriptionAuditLog[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([enterpriseId])
}

/** Per-Stripe-event idempotency + observability log.
 *
 *  The webhook handler upserts a row keyed by Stripe's `event.id` BEFORE
 *  running any business logic. The dedupe gate is `processedAt != null` —
 *  PROCESSED and IGNORED both set processedAt (both are terminal, no need
 *  to re-run); FAILED leaves it null so Stripe's retry can take another
 *  attempt against the same row. RECEIVED rows are in-flight.
 *
 *  Recording IGNORED rows for unhandled event types gives us a complete
 *  audit trail of what Stripe sent us, even if our handler currently has no
 *  case for it. Volume can grow; consider a TTL/GC follow-up.
 */
model StripeWebhookEvent {
  /** Stripe's event.id, e.g. `evt_1Abc...`. Primary key for natural dedupe. */
  id            String                @id
  eventType     String
  /** Stripe's `event.created` (Unix seconds → Date). Snapshot at receipt
   *  time. Used by the ordering check inside subscription-mutating cases. */
  eventCreated  DateTime
  receivedAt    DateTime              @default(now())
  /** Set on terminal outcomes (PROCESSED, IGNORED). Null while RECEIVED or
   *  if the handler threw (FAILED). The dedupe gate is `processedAt != null`. */
  processedAt   DateTime?
  status        WebhookProcessStatus  @default(RECEIVED)

  @@index([eventType, receivedAt])
}

enum WebhookProcessStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

model SubscriptionAuditLog {
  id               String            @id @default(cuid())
  subscriptionId   String
  action           String
  previousTier     SubscriptionTier?
  newTier          SubscriptionTier?
  metadata         Json?
  timestamp        DateTime          @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

/** Singleton row (`id = "default"`): global toggles managed in Admin → Settings. */
model PlatformSettings {
  id     String @id @default("default")
  /** Advisor nav + /advisor/governance dashboard (Family Portfolio, metrics). */
  advisorGovernanceDashboardEnabled Boolean @default(true)
  /** Advisor nav + /advisor/intelligence (portfolio risk views). */
  advisorRiskIntelligenceEnabled    Boolean @default(true)
  /** Workflow nav: Tasks (hidden until super admin enables). */
  advisorWorkflowTasksEnabled       Boolean @default(false)
  /** Workflow nav: Follow-ups (hidden until super admin enables). */
  advisorWorkflowFollowUpsEnabled   Boolean @default(false)
  /** Pipeline chevron + post-report monitoring phase (hidden until super admin enables). */
  advisorMonitoringEnabled          Boolean @default(false)
  /// A2 (BRD §4.2 + §7.1): risk-tier cutoffs in 0–100 resilience-percent space.
  /// Configured at /admin/scoring/thresholds. NEW scoring runs use these;
  /// previously-persisted PillarScore.riskLevel rows are NOT retroactively
  /// recomputed (would require a re-score). Defaults match the original
  /// hardcoded values from governance-rubric.ts so behavior is unchanged
  /// until an admin edits them.
  riskThresholdLow    Int @default(80)
  riskThresholdMedium Int @default(60)
  riskThresholdHigh   Int @default(40)
  /** Legacy platform toggle; MFA enrollment is optional for all roles. */
  mfaRequiredForAllRoles Boolean @default(false)
  /** Super-admin password rules for credential-based accounts. */
  passwordMinLength Int @default(8)
  passwordRequireUppercase Boolean @default(true)
  passwordRequireNumber Boolean @default(true)
  passwordRequireSpecialCharacter Boolean @default(false)
  passwordPolicyRevision Int @default(1)
  passwordComplianceNotice String?
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  mfaVerified  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)

  @@unique([identifier, token])
}

/// Round-11 commit 2 (BRD §5.1.AUTH): magic-link authentication tokens for
/// client users. Sibling to NextAuth's VerificationToken (which holds
/// password-reset tokens for advisor accounts). Single-use, 15-minute
/// expiry by default; raw token hashed via SHA-256 before storage.
model MagicLinkToken {
  id           String    @id @default(cuid())
  /// SHA-256 hash of the random 32-byte token sent to the user. The raw
  /// token only exists in transit (the email body) and during validation.
  tokenHash    String    @unique
  /// Email the link is bound to. Validation uses tokenHash for lookup;
  /// email is stored for audit + display only.
  email        String
  /// Optional FK to the originating InviteCode when the link is issued
  /// as part of advisor invitation. Null for self-service sign-in
  /// requests by existing users. SetNull on delete so an invite removal
  /// doesn't cascade-kill in-flight tokens.
  inviteCodeId String?
  expires      DateTime
  used         Boolean   @default(false)
  /// When the link was clicked (used flips true). Null until clicked.
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  inviteCode   InviteCode? @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expires])
}

model Assessment {
  id            String           @id @default(cuid())
  userId        String
  /// C2 (BRD §7.2): bumped each time rescoreAssessment runs. Pre-rescore
  /// the value is 1 (default); first rescore writes 2, etc. Lets the UI
  /// surface "v3" badges without consulting the audit log.
  version       Int              @default(1)
  status        AssessmentStatus @default(IN_PROGRESS)
  currentPillar String?
  currentQuestionIndex Int?      @default(0)
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  /// C2 (BRD §7.2): set by rescoreAssessment / rescoreAssessmentsBulk so
  /// the per-client view + PDF cover can render "Last re-scored Mar 4, 2026".
  /// NULL = never re-scored (true of every pre-C2 row).
  lastRescoredAt DateTime?
  /// Set when a client changes stored answers after status COMPLETED.
  /// Cleared when an admin re-score runs. Drives advisor re-score cues.
  answersChangedAfterCompleteAt DateTime?
  updatedAt     DateTime         @updatedAt
  approvalId    String?          // Links to IntakeApproval for customized assessments
  /// Frozen advisor methodology at intake start (10-pillar advisor methodology).
  snapshotId    String?          @map("snapshot_id")
  /// Epic 5.11: advisor-selected pillar scope (1–6 canonical ids). Empty array
  /// means all six pillars (legacy / pre-approval backfill).
  includedPillars String[]       @default([]) @map("included_pillars")

  /// BRD §6.3 / Epic 5.10: which deliverable phase this assessment is in.
  /// Set to PREVIEW on scoring completion, PROFILE on report publish, and
  /// PORTFOLIO when the client accepts the recommendation.
  deliverablePhase   DeliverablePhase @default(PREVIEW)
  previewEnteredAt   DateTime?
  profileEnteredAt   DateTime?
  portfolioEnteredAt DateTime?
  /// BRD §6.2 / Epic 5.10: snapshot of upsell triggers that fired at the
  /// time the assessment was scored / re-scored. Array of typed codes such
  /// as `"score_threshold:overall"`, `"domain_flag:cyber-digital"`, or
  /// `"kri:<questionId>"`.
  upsellTriggersFired    Json?
  actionPlanPublishedAt  DateTime? @map("action_plan_published_at")

  /// Phase 24 (D-04): self-referential link for reassessment versioning.
  /// Each reassessment creates a new Assessment row linked to its predecessor.
  /// Reassessment sequence number is derived from chain length (not `version`).
  previousAssessmentId String? @map("previous_assessment_id")
  previousAssessment   Assessment?  @relation("AssessmentChain", fields: [previousAssessmentId], references: [id], onDelete: SetNull)
  nextAssessments      Assessment[] @relation("AssessmentChain")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     AssessmentResponse[]
  scores        PillarScore[]
  recommendations AssessmentRecommendation[]
  ruleExecutions    RuleExecution[]
  /// §4.5 commit 3 (BRD §4.5): published + draft + superseded report
  /// versions. Cascade on delete so RTBF wipes every Report row for this
  /// assessment (frozen reports include client PII in snapshotData).
  reports        Report[]
  portfolioEngagement PortfolioEngagement?
  snapshot            IntakeSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  /// Phase 24 (D-11): assessment-scoped intelligence events (not tied to a recommendation).
  intelligenceEvents  SolutionActivity[] @relation("AssessmentIntelligenceEvents")
  /// Phase 24 (D-08): review cadence entries pointing to this as last completed assessment.
  reviewCadences      ReviewCadence[]

  @@index([userId])
  @@index([status])
  @@index([deliverablePhase])
  @@index([snapshotId])
  @@index([previousAssessmentId])
}

model AssessmentResponse {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String
  pillar       String
  subCategory  String
  /// Round-11 commit 2.5b (BRD §5.1): random-IV AES-256-GCM ciphertext
  /// of JSON.stringify(answer). Nullable for `skipped = true` rows.
  /// Use the helpers in `src/lib/data/response-content.ts`
  /// (encryptAnswer / decryptAnswer<T>) — never read this column
  /// directly. The plaintext `answer Json` column was dropped by the
  /// 2.5b finalize migration; this column was renamed from
  /// `answerCiphertext` to take its place.
  answer       String?
  skipped      Boolean  @default(false)
  answeredAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  adminNote    AssessmentResponseAdminNote?
  /// US-46c: zero-or-more advisor notes — one per assigned advisor. Two
  /// active advisors on the same client can each leave their own note.
  advisorNotes AssessmentResponseAdvisorNote[]

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
}

/// US-46b: platform-admin advisory note on a single assessment answer.
/// Does not modify the encrypted answer or scoring inputs.
model AssessmentResponseAdminNote {
  id                   String   @id @default(cuid())
  assessmentResponseId String   @unique
  body                 String   @db.Text
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assessmentResponse AssessmentResponse @relation(fields: [assessmentResponseId], references: [id], onDelete: Cascade)
  createdBy          User               @relation("AssessmentResponseAdminNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy          User?              @relation("AssessmentResponseAdminNoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
}

/// US-46c: per-advisor advisory note on a single assessment answer. Sister
/// to AssessmentResponseAdminNote (US-46b) — both channels coexist on the
/// same response and neither overwrites the other. `advisorId` is the
/// advisor User (not AdvisorProfile) for parity with createdBy/updatedBy.
/// Tenant isolation (ACTIVE ClientAdvisorAssignment) is enforced at the
/// application layer, not the DB schema.
model AssessmentResponseAdvisorNote {
  id                   String   @id @default(cuid())
  assessmentResponseId String
  advisorId            String
  body                 String   @db.Text
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assessmentResponse AssessmentResponse @relation(fields: [assessmentResponseId], references: [id], onDelete: Cascade)
  advisor            User               @relation("AssessmentResponseAdvisorNoteAdvisor", fields: [advisorId], references: [id], onDelete: Cascade)
  createdBy          User               @relation("AssessmentResponseAdvisorNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy          User?              @relation("AssessmentResponseAdvisorNoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([assessmentResponseId, advisorId])
  @@index([advisorId])
  @@index([createdByUserId])
}

model PillarScore {
  id           String    @id @default(cuid())
  assessmentId String
  pillar       String
  score        Float
  riskLevel    RiskLevel
  breakdown    Json
  missingControls Json?
  calculatedAt DateTime  @default(now())

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, pillar])
  @@index([assessmentId])
}


/// Platform `categories` row: intake bank vs. scored assessment pillars (see `kind`).
enum PillarCategoryKind {
  INTAKE
  ASSESSMENT

  @@map("pillar_category_kind")
}

/// Platform question bank taxonomy (intake bank + assessment). Maps to SQL table `categories`.
model PillarCategory {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String             @unique @db.VarChar(50)
  name         String             @db.VarChar(200)
  sheetName    String?            @map("sheet_name") @db.VarChar(200)
  displayOrder Int                @default(0) @map("display_order")
  /// `INTAKE` = audio interview script; `ASSESSMENT` = scored pillar workbook tabs.
  kind         PillarCategoryKind @default(ASSESSMENT) @map("category_kind")
  sections     PillarSection[]

  @@index([displayOrder])
  @@map("categories")
}

/// Section within a pillar category (e.g. rubric block A–F or numbered block).
/// Maps to SQL table `sections`.
model PillarSection {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId String         @map("category_id") @db.Uuid
  code         String         @db.VarChar(20)
  name         String         @db.VarChar(300)
  objective    String?        @db.Text
  weightPct    Int?           @map("weight_pct")
  displayOrder Int            @default(0) @map("display_order")

  category  PillarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  questions PillarQuestion[]

  @@unique([categoryId, code])
  @@index([categoryId])
  @@index([displayOrder])
  @@map("sections")
}

/// Question row in the intake bank or assessment question bank (answer labels, types, cross-references).
/// Maps to SQL table `questions`.
model PillarQuestion {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId            String   @map("section_id") @db.Uuid
  questionNumber       String?  @map("question_number") @db.VarChar(20)
  questionText         String   @map("question_text") @db.Text
  answerType           String   @default("scored_0_3") @map("answer_type") @db.VarChar(50)
  answer0              String?  @map("answer_0") @db.Text
  answer1              String?  @map("answer_1") @db.Text
  answer2              String?  @map("answer_2") @db.Text
  answer3              String?  @map("answer_3") @db.Text
  whyThisMatters       String?  @map("why_this_matters") @db.Text
  recommendedActions   String?  @map("recommended_actions") @db.Text
  isSubQuestion         Boolean  @default(false) @map("is_sub_question")
  crossReference       String?  @map("cross_reference") @db.Text
  displayOrder         Int      @default(0) @map("display_order")
  isVisible            Boolean  @default(true) @map("is_visible")
  /// BRD §6.2 / Epic 5.10: marks the question as a Key Risk Indicator. A
  /// KRI-flagged question fires an upsell trigger when answered at a
  /// failing maturity level (≤ 1), regardless of the pillar's overall
  /// score. Managed in the question-bank admin (US-37 extension).
  isKeyRiskIndicator   Boolean  @default(false) @map("is_key_risk_indicator")
  /// Epic 5.11 / US-77: intake questions linked to assessment pillars for
  /// advisor recommendations at approval time.
  relatedPillarIds     String[] @default([]) @map("related_pillar_ids")

  section PillarSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  advisorAssessmentClones AdvisorPillarQuestion[] @relation("AdvisorAssessmentPlatformSource")
  advisorIntakeClones     AdvisorIntakeQuestion[] @relation("AdvisorIntakePlatformSource")
  enterpriseAssessmentClones EnterprisePillarQuestion[] @relation("EnterpriseAssessmentPlatformSource")
  enterpriseIntakeClones     EnterpriseIntakeQuestion[] @relation("EnterpriseIntakePlatformSource")

  @@unique([sectionId, questionNumber])
  @@unique([sectionId, displayOrder])
  @@index([sectionId])
  @@index([answerType])
  @@index([isVisible])
  @@index([isKeyRiskIndicator])
  @@map("questions")
}

