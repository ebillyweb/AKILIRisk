# Database
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local development (Docker): postgresql://postgres:postgres@localhost:5443/belvedere
# For local Postgres on default port: postgresql://postgres:postgres@localhost:5432/belvedere
# For production: Get from your PostgreSQL provider (Neon, Supabase, Railway, etc.)
# Hosted URLs often use ?sslmode=require; the app normalizes that to verify-full for the Node pg driver.
# To set it yourself: ?sslmode=verify-full (stricter hostname/cert checks than libpq-style require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5443/belvedere"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# Application URL
# For local development: http://localhost:3000
# For production / Vercel: https://your-domain.com (or https://your-project.vercel.app), no trailing path
# Auth.js reads AUTH_URL; legacy NEXTAUTH_URL also works if you already use it in Vercel.
# Include the scheme: use https://... not example.com alone (Stripe Checkout requires valid absolute URLs).
# Billing redirect URLs prefer the incoming request host (production custom domain). Fallback:
# AUTH_URL → NEXT_PUBLIC_URL → NEXTAUTH_URL → https://VERCEL_URL → localhost.
# Use a full https:// origin in Vercel (no quotes, no line breaks in the value).
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_URL="http://localhost:3000"

# Email (Resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
# For development, use: onboarding@resend.dev
# For production, verify your domain and use your domain email
FROM_EMAIL="onboarding@resend.dev"

# OpenAI
# Required for intake transcription and question text-to-speech
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# AWS (S3 branding / uploads) — Akili org / buddy@ebilly.com. IAM keys below must be from this account.
# CLI / SSO: profile name is often buddy@ebilly.com in ~/.aws/config (must include sso_start_url etc.). Cursor terminals set the same.
AWS_PROFILE="buddy@ebilly.com"
# CORS script ignores inherited AWS_PROFILE (see scripts/apply-s3-browser-upload-cors.sh); override its default with:
# AKILI_AWS_PROFILE=your-profile-name
# Region must match the bucket (CLI: curl -sI "https://$BUCKET.s3.amazonaws.com/" | grep x-amz-bucket-region)
AWS_REGION="us-east-2"
# If AWS_REGION is something else but this bucket is in us-east-2, set explicitly:
# S3_BRANDING_REGION="us-east-2"
# Presigned document uploads use the same region as the bucket (defaults: S3_BRANDING_REGION → AWS_REGION):
# S3_DOCUMENTS_REGION="us-east-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BRANDING_BUCKET="akili-advisor-assets"
# Intake voice-response audio (server-side PUT, authenticated streaming proxy).
# Falls back to S3_BRANDING_BUCKET when unset; set S3_INTAKE_BUCKET if you
# want intake audio isolated from branding assets.
# S3_INTAKE_BUCKET="akili-intake-audio"
# Falls back to S3_BRANDING_REGION → AWS_REGION; set if the intake bucket
# lives in a different region than the branding bucket.
# S3_INTAKE_REGION="us-east-2"
# Client document collection (presigned PUT). Often same bucket as branding.
S3_BUCKET_NAME="akili-advisor-assets"
# Browser uploads need bucket CORS. From repo root: S3_BUCKET_NAME=akili-advisor-assets ./scripts/apply-s3-browser-upload-cors.sh
# (needs IAM s3:PutBucketCors, or paste scripts/s3-browser-upload-cors.json in S3 Console → bucket → Permissions → CORS.)

# Optional: CloudFront or custom base for public logo URLs (otherwise regional S3 virtual host is used)
# CLOUDFRONT_BASE_URL="https://dxxxx.cloudfront.net"

# White-label subdomain DNS instructions. Required by the subdomain-claim
# API; if unset the route fails fast with a 500 rather than handing
# advisors DNS records pointing at the wrong domain. Set to your apex
# (the one *.akilirisk.com or equivalent customer subdomains target).
PRODUCTION_DOMAIN="akilirisk.com"

# Encryption
# Generate with: openssl rand -base64 32
# Used for encrypting sensitive data like MFA secrets
ENCRYPTION_KEY="your-encryption-key-here"

# Stripe (advisor billing)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From Stripe CLI or Dashboard webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Recurring price IDs from Stripe Dashboard (Products → Prices)
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_ANNUAL="price_..."
STRIPE_PRICE_GROWTH_MONTHLY="price_..."
STRIPE_PRICE_GROWTH_ANNUAL="price_..."
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_..."
STRIPE_PRICE_PROFESSIONAL_ANNUAL="price_..."
BILLING_GRACE_PERIOD_DAYS="14"
DEFAULT_MIGRATION_TIER="GROWTH"
# Set to "false" to disable client-limit enforcement and billing UI requirements
ENABLE_BILLING_FEATURES="true"

# Cron endpoints (Vercel Cron / external scheduler) — shared secret presented
# as `Authorization: Bearer <CRON_SECRET>`. Compared with crypto.timingSafeEqual
# in the cron route handlers; the routes 500 if this is unset.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Audit-log retention window in days. Read by /api/cron/audit-log-retention
# (run nightly via the same cron scheduler that hits the *-reminders routes).
# Rows older than this are deleted; the sweep self-audits one
# `system.retention_sweep` row per execution. Defaults to 365 if unset or
# malformed. BRD §5.5 calls for configurable retention.
AUDIT_LOG_RETENTION_DAYS="365"

# Debug TOTP endpoint at /api/debug/totp — generates and verifies TOTP
# secrets/tokens for local development. The route logs raw secrets, has no
# auth, and exposes error.stack on failure. Two independent gates must
# both pass: NODE_ENV !== "production" AND ALLOW_DEBUG_TOTP="1". Vercel's
# default NODE_ENV=production keeps it off in prod; this opt-in keeps it
# off in dev/staging unless explicitly enabled. Leave unset (or "0") in
# any environment reachable over the public internet.
# ALLOW_DEBUG_TOTP="1"

# Round-11 session-2: enable the test-only magic-link issuance endpoint
# /api/test/magic-link/issue. Returns the raw magic-link token so
# Playwright client smokes can drive the real magic-link flow without
# scraping email. Two independent gates must both pass to expose the
# endpoint: NODE_ENV !== "production" AND ENABLE_TEST_AUTH="1". Set this
# to "1" in .env.local when running Playwright locally, and on the
# Vercel Preview environment for preview.akilirisk.com smokes.
#
# DO NOT enable this in production. The endpoint exposes single-use
# auth tokens to any caller; combined with a known seeded client email
# this is equivalent to "log in as that user" superpower. Vercel sets
# NODE_ENV=production by default in prod deployments which would 404
# the endpoint anyway, but this opt-in is the belt for the suspenders.
# ENABLE_TEST_AUTH="1"

# Assessment question bank (spreadsheet is source of truth)
# Default file: Belvedere_Household_Risk_Profile.xlsx at repo root. Override path:
# BELVEDERE_WORKBOOK_PATH="/absolute/or/relative/path/to/Belvedere_Household_Risk_Profile.xlsx"
# If no workbook (or CI): allow seeding from TypeScript catalog in src/lib/assessment/questions.ts instead:
# QUESTION_BANK_FALLBACK_TYPESCRIPT="1"
#
# Pillar bank (`categories` / `sections` / `questions`, Belvedere DDL): when `questions` has any rows,
# the assessment API uses that bank (DDL is source of truth). `AssessmentBankQuestion` is ignored then.
# USE_PILLAR_QUESTION_BANK="0" — never use pillar tables; always use `AssessmentBankQuestion`.
#
# Pillar DDL bulk load (categories / sections / questions): after migrations, run `npm run seed:pillar-ddl`.
# Optional path to your Belvedere .sql (default: scripts/sql/belvedere-pillar-ddl-seed.sql):
# PILLAR_DDL_SEED_PATH="./scripts/sql/belvedere-pillar-ddl-seed.sql"
#
# Optional: import Reputational & social risk only (see npm run import:reputational-social)
# Starter CSV (edit IDs/text before production): examples/reputational-social-import-template.csv
# REPUTATIONAL_SOCIAL_IMPORT_PATH="./examples/reputational-social-import-template.csv"
# REPUTATIONAL_SOCIAL_SHEET_NAME="Reputational & Social Risk"

# Playwright smoke (`npm run test:e2e`)
# Default base URL is preview; scripts like reset-fresh-client-intake still use DATABASE_URL — start Postgres
# (e.g. docker compose) or point DATABASE_URL at the same DB the app under test uses.
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# Run Stripe webhook smoke against a remote deployment only after STRIPE_WEBHOOK_SECRET matches there:
# E2E_STRIPE_WEBHOOK_REMOTE="1"

# Sync env from Vercel (Node >= 20.19; no global CLI needed — use npx)
# Login once: `npx vercel login`
# Link this repo to the Vercel project (creates .vercel/project.json; gitignored):
#   npm run env:vercel:link
# Pull Preview / Production / Development into .env.local (overrides .env for same keys):
#   npm run env:vercel:preview
#   npm run env:vercel:production
#   npm run env:vercel
# Do not run bare `vercel link` unless `vercel` is on your PATH; use `npx vercel link` or the npm script above.
# Avoid `npx vercel env pull .env` — it replaces the entire file and drops comments/local-only keys.
