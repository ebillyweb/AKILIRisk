# Database
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local development (Docker): postgresql://postgres:postgres@localhost:5443/belvedere
# For local Postgres on default port: postgresql://postgres:postgres@localhost:5432/belvedere
# For production: Get from your PostgreSQL provider (Neon, Supabase, Railway, etc.)
# Hosted URLs often use ?sslmode=require; the app normalizes that to verify-full for the Node pg driver.
# To set it yourself: ?sslmode=verify-full (stricter hostname/cert checks than libpq-style require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5443/belvedere"
# Prisma Migrate (Vercel build / CLI): direct Postgres URL — not the Neon pooler.
# On Neon, copy DATABASE_URL and remove "-pooler" from the hostname, or use the
# "Direct connection" string from the Neon dashboard.
# DIRECT_URL="postgresql://user:pass@ep-xxx.c-2.us-east-2.aws.neon.tech/akili_db?sslmode=require"
# Vercel: set DIRECT_URL on Production (and Preview/staging if RUN_PRISMA_MIGRATE_DEPLOY=1).
# Preview deploys skip migrate by default (see scripts/vercel-build.sh).

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# Application URL
# For local development: http://localhost:3000
# For production / Vercel: https://your-domain.com (or https://your-project.vercel.app), no trailing path
# Auth.js reads AUTH_URL; legacy NEXTAUTH_URL also works if you already use it in Vercel.
# Include the scheme: use https://... not example.com alone (Stripe Checkout requires valid absolute URLs).
# Billing redirect URLs prefer the incoming request host (production custom domain). Fallback:
# AUTH_URL → NEXT_PUBLIC_URL → NEXTAUTH_URL → https://VERCEL_URL → localhost.
# Use a full https:// origin in Vercel (no quotes, no line breaks in the value).
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_URL="http://localhost:3000"
# Legacy name still read by some email/reminder code paths. On Vercel Preview/Production set to the
# same https origin as AUTH_URL (not localhost) so links in outbound mail are correct.
# NEXTAUTH_URL="https://your-deployment.example.com"

# Email (Resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
# For development, use: onboarding@resend.dev
# For production, verify your domain and use your domain email
FROM_EMAIL="onboarding@resend.dev"
# Inbound contact form (/contact) — Resend delivers to this address (defaults to buddy@ebilly.com)
# CONTACT_FORM_TO_EMAIL="you@example.com"

# Cloudflare Turnstile (contact + assessment request forms)
# Create keys: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Local dev only when Turnstile keys are unset (never enable in production):
# CONTACT_FORM_SKIP_CAPTCHA="1"

# OpenAI
# Required for intake transcription and question text-to-speech
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# AWS (S3 branding / uploads) — Akili org / buddy@ebilly.com. IAM keys below must be from this account.
# CLI / SSO: profile name is often buddy@ebilly.com in ~/.aws/config (must include sso_start_url etc.). Cursor terminals set the same.
AWS_PROFILE="buddy@ebilly.com"
# CORS script ignores inherited AWS_PROFILE (see scripts/apply-s3-browser-upload-cors.sh); override its default with:
# AKILI_AWS_PROFILE=your-profile-name
# Region must match the bucket (CLI: curl -sI "https://$BUCKET.s3.amazonaws.com/" | grep x-amz-bucket-region)
AWS_REGION="us-east-2"
# If AWS_REGION is something else but this bucket is in us-east-2, set explicitly:
# S3_BRANDING_REGION="us-east-2"
# Presigned document uploads use the same region as the bucket (defaults: S3_BRANDING_REGION → AWS_REGION):
# S3_DOCUMENTS_REGION="us-east-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Presigned advisor logo / branding uploads. Required — no hardcoded production default.
S3_BRANDING_BUCKET="akili-advisor-assets"
# Optional: KMS key ARN or alias for S3 SSE-KMS. Recommend: customer-managed key
# (CMK) per environment, with rotation enabled and a key policy granting the app's
# IAM principal kms:GenerateDataKey + kms:Decrypt. When unset, S3 falls back to
# SSE-S3 (AES-256, AWS-managed) which keeps dev/CI working without a real key.
# See docs/operations/s3-sse-kms.md for the full provisioning sequence.
# S3_KMS_KEY_ID="alias/akili-prod-s3"
# Intake voice-response audio (server-side PUT, authenticated streaming proxy).
# Required — no fallback to S3_BRANDING_BUCKET. If older recordings landed in
# the branding bucket, run: npm run s3:copy-intake-audio-to-intake-bucket
S3_INTAKE_BUCKET="akili-intake-audio"
# Optional; defaults to AWS_REGION (then us-east-2).
# S3_INTAKE_REGION="us-east-2"
# Client document collection (presigned PUT). Often same bucket as branding.
S3_BUCKET_NAME="akili-advisor-assets"
# Browser uploads need bucket CORS. From repo root: S3_BUCKET_NAME=akili-advisor-assets ./scripts/apply-s3-browser-upload-cors.sh
# (needs IAM s3:PutBucketCors, or paste scripts/s3-browser-upload-cors.json in S3 Console → bucket → Permissions → CORS.)

# Optional: CloudFront or custom base for public logo URLs (otherwise regional S3 virtual host is used)
# CLOUDFRONT_BASE_URL="https://dxxxx.cloudfront.net"

# White-label advisor portals — full guide: docs/white-label-subdomains.md
# PRODUCTION_DOMAIN — apex (required for subdomain claim).
PRODUCTION_DOMAIN="akilirisk.com"
# Preview/staging: tenant portals at preview.akilirisk.com/t/{slug}.
# Auto-enabled on Vercel Preview, preview.{PRODUCTION_DOMAIN}, or when AUTH_URL
# points at the staging platform host. Override with TENANT_PATH_PORTALS=true|false.
# TENANT_PATH_PORTALS="true"
# Legacy hostname suffix when TENANT_PATH_PORTALS=false (deprecated on Preview):
# TENANT_SUBDOMAIN_SUFFIX="-staging"
# Auto-activate advisor subdomains on claim (default true; false on Vercel Preview
# unless set to true). Set false to require manual dnsVerified/isActive in DB.
# SUBDOMAIN_AUTO_ACTIVATE="true"
# Extra platform hosts that skip tenant routing (comma-separated FQDNs).
# PLATFORM_HOSTS="preview.akilirisk.com"
# Extra reserved slug labels advisors cannot claim (comma-separated).
# PLATFORM_SUBDOMAIN_LABELS="internal,demo"

# Encryption
# Generate with: openssl rand -base64 32 (isolated local DB only)
# Shared Preview Neon DB: copy ENCRYPTION_KEY from Vercel Preview — must match exactly.
# Mismatch → "Unsupported state or unable to authenticate data" on admin/advisor pages.
# See docs/LOCAL_DEVELOPMENT_TROUBLESHOOTING.md
ENCRYPTION_KEY="your-encryption-key-here"

# Stripe (advisor billing)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From Stripe CLI or Dashboard webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Recurring price IDs from Stripe Dashboard (Products → Prices)
# Create with: STRIPE_SECRET_KEY=sk_test_... node scripts/provision-stripe-tier-products.mjs
STRIPE_PRICE_ESSENTIALS_MONTHLY="price_..."
STRIPE_PRICE_ESSENTIALS_ANNUAL="price_..."
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_..."
STRIPE_PRICE_PROFESSIONAL_ANNUAL="price_..."
STRIPE_PRICE_BUSINESS_MONTHLY="price_..."
STRIPE_PRICE_BUSINESS_ANNUAL="price_..."
STRIPE_PRICE_PLATINUM_MONTHLY="price_..."
STRIPE_PRICE_PLATINUM_ANNUAL="price_..."
# Each tier requires its own STRIPE_PRICE_{TIER}_{MONTHLY|ANNUAL} — legacy Starter/Growth aliases are not read.
BILLING_GRACE_PERIOD_DAYS="14"
DEFAULT_MIGRATION_TIER="PROFESSIONAL"
# Set to "false" to disable client-limit enforcement and billing UI requirements
ENABLE_BILLING_FEATURES="true"
# Push the Stripe + billing keys above from `.env.local` (or `--file=`) to Vercel Preview (Git branch) + Development: npm run env:vercel:sync-stripe
# Live Stripe: use Stripe CLI to resolve live Price IDs + push sk_live/pk_live to Vercel Production — see npm run env:vercel:sync-stripe-live-production (requires STRIPE_SECRET_KEY + STRIPE_LIVE_PUBLISHABLE_KEY)
# Optional: `1` enables [advisor-billing] console.debug on `/advisor/billing` in production builds; `0` silences in dev.
# NEXT_PUBLIC_DEBUG_ADVISOR_BILLING="1"

# Cron endpoints (Vercel Cron / external scheduler) — shared secret presented
# as `Authorization: Bearer <CRON_SECRET>`. Compared with crypto.timingSafeEqual
# in the cron route handlers; the routes 500 if this is unset.
# Generate with: openssl rand -hex 32
CRON_SECRET=""
# BullMQ enterprise provisioning (POC). Uses Upstash when connected on Vercel:
# UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN (injected by the integration).
# Optional override: explicit TCP URL from Upstash Console → Connect → Redis:
# REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379"
# Playwright cron smokes against preview (same secret on Vercel Preview + CI):
# E2E_CRON_REMOTE="1"

# Audit-log retention window in days. Read by /api/cron/audit-log-retention
# (run nightly via the same cron scheduler that hits the *-reminders routes).
# Rows older than this are deleted; the sweep self-audits one
# `system.retention_sweep` row per execution. Defaults to 365 if unset or
# malformed. BRD §5.5 calls for configurable retention.
AUDIT_LOG_RETENTION_DAYS="365"

# Debug TOTP endpoint at /api/debug/totp — generates and verifies TOTP
# secrets/tokens for local development. The route logs raw secrets, has no
# auth, and exposes error.stack on failure. Two independent gates must
# both pass: NODE_ENV !== "production" AND ALLOW_DEBUG_TOTP="1". Vercel's
# default NODE_ENV=production keeps it off in prod; this opt-in keeps it
# off in dev/staging unless explicitly enabled. Leave unset (or "0") in
# any environment reachable over the public internet.
# ALLOW_DEBUG_TOTP="1"

# Round-11 session-2: enable the test-only magic-link issuance endpoint
# /api/test/magic-link/issue. Returns the raw magic-link token so
# Playwright client smokes can drive the real magic-link flow without
# scraping email. Also enables /api/test/password-reset/latest to return
# the raw password-reset token after POST /api/auth/forgot-password (same
# email-trap bypass for advisor/admin password-reset E2E). Gated by
# isTestAuthEnabled() (src/lib/auth/test-auth-enabled.ts):
# ENABLE_TEST_AUTH="1" plus non-production runtime (local dev or Vercel Preview).
# Set to "1" in .env.local when running Playwright locally, and on the
# Vercel Preview environment for preview.akilirisk.com smokes.
#
# DO NOT enable this in production. The endpoint exposes single-use
# auth tokens to any caller; combined with a known seeded client email
# this is equivalent to "log in as that user" superpower. Vercel Production
# (VERCEL_ENV=production) is always blocked even if this var is set.
# ENABLE_TEST_AUTH="1"
#
# With ENABLE_TEST_AUTH, Playwright also uses:
#   POST /api/test/magic-link/issue — raw magic-link token for client sign-in
#   POST /api/test/password-reset/latest — raw reset token after forgot-password
#   POST /api/test/invitation/issue — create advisor invitations and get signup URLs
#   (tests/smoke/client-invitation-onboarding.spec.ts)
#   POST /api/test/mfa/prepare — enable or reset MFA for advisor/admin test users
#   (tests/smoke/epic-5.6-mfa-sign-in.spec.ts; body { email, resetOnly? })
#   POST /api/test/user/deactivate — soft-delete or restore *@test.com users
#   (tests/smoke/epic-5.6-rbac.spec.ts; body { email, restoreOnly? })
#   POST /api/test/assessment/prepare — score all six pillars for a client email
#   (tests/smoke/epic-5.2-report-publish.spec.ts)
#   tests/smoke/epic-5.4-documents-cron-sse.spec.ts — S3 upload (AWS_* + S3_BUCKET_NAME),
#   cron GET with CRON_SECRET, pipeline SSE (2s poll while ENABLE_TEST_AUTH=1)

# Assessment question bank (spreadsheet is source of truth)
# Default file: Belvedere_Household_Risk_Profile.xlsx at repo root. Override path:
# BELVEDERE_WORKBOOK_PATH="/absolute/or/relative/path/to/Belvedere_Household_Risk_Profile.xlsx"
#
# Pillar bank (`categories` / `sections` / `questions`) holds the intake bank and assessment question bank.
# There is no legacy fallback: if the pillar bank is empty, the assessment surfaces an error.
#
# Pillar DDL bulk load (intake bank + assessment question bank): after migrations, run `npm run seed:pillar-ddl`.
# Optional path to your platform seed .sql (default: scripts/sql/belvedere-pillar-ddl-seed.sql):
# PILLAR_DDL_SEED_PATH="./scripts/sql/belvedere-pillar-ddl-seed.sql"
#
# Optional: import Reputational & social risk only (see npm run import:reputational-social)
# Starter CSV (edit IDs/text before production): examples/reputational-social-import-template.csv
# REPUTATIONAL_SOCIAL_IMPORT_PATH="./examples/reputational-social-import-template.csv"
# REPUTATIONAL_SOCIAL_SHEET_NAME="Reputational & Social Risk"

# Playwright smoke (`npm run test:e2e`)
# Default base URL is preview; scripts like reset-fresh-client-intake still use DATABASE_URL — start Postgres
# (e.g. docker compose) or point DATABASE_URL at the same DB the app under test uses.
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# Run Stripe webhook smoke against a remote deployment only after STRIPE_WEBHOOK_SECRET matches there:
# E2E_STRIPE_WEBHOOK_REMOTE="1"

# Sync env from Vercel (Node >= 20.19; no global CLI needed — use npx)
# Login once: `npx vercel login`
# Link this repo to the Vercel project (creates .vercel/project.json; gitignored):
#   npm run env:vercel:link
# Pull Preview / Production / Development into .env.local:
#   npm run env:vercel:preview
#   npm run env:vercel:production
#   npm run env:vercel
# Do not run bare `vercel link` unless `vercel` is on your PATH; use `npx vercel link` or the npm script above.
# Avoid `npx vercel env pull .env` — it replaces the entire file and drops comments/local-only keys.

# --- Mobile app (Expo) integration ---
# Base URL used to build magic-link sign-in URLs sent to the mobile app.
# Falls back to NEXTAUTH_URL, then https://app.akilirisk.com.
MOBILE_LINK_BASE_URL="http://localhost:3000"
# iOS universal links: full app identifier "TEAMID.bundleId" (or set APPLE_TEAM_ID
# and the bundle com.ebilly.akilirisk is assumed). Served at
# /.well-known/apple-app-site-association.
APPLE_APP_ID=""
APPLE_TEAM_ID=""
# Android app links: comma-separated SHA-256 signing-cert fingerprints from
# EAS / Play App Signing. Served at /.well-known/assetlinks.json.
ANDROID_SHA256_CERT_FINGERPRINTS=""

# --- Public marketing / SEO ---
# Optional social profile URLs (footer links + Organization schema sameAs).
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL="https://www.linkedin.com/company/your-page"
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL="https://www.facebook.com/your-page"
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL="https://www.instagram.com/your-page"
# NEXT_PUBLIC_SOCIAL_X_URL="https://x.com/your-handle"
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL="https://www.youtube.com/@your-channel"
# Optional Facebook Pixel for ad retargeting (loads only when set).
# NEXT_PUBLIC_FB_PIXEL_ID=""

# --- Tests ---
# Set to a throwaway Postgres URL to run the opt-in DB integration tests
# (apply migrations first: TEST_DATABASE_URL=... npx prisma migrate deploy).
TEST_DATABASE_URL=""
